<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vaulta Club — Ouvre. Collectionne. Échange.</title>
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Exo+2:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{--vc-bg:#08080e;--vc-bg-card:#0e0e1a;--vc-bg-surface:#141422;--vc-bg-elevated:#1c1c32;--vc-bg-hover:#222240;--vc-primary:#6366f1;--vc-primary-light:#818cf8;--vc-primary-dark:#4338ca;--vc-secondary:#7c3aed;--vc-accent:#a78bfa;--vc-blue:#3b82f6;--vc-gold:#fbbf24;--vc-fire:#ef4444;--vc-green:#34d399;--vc-cyan:#22d3ee;--vc-pink:#f472b6;--vc-text:#e8e8f0;--vc-text-secondary:#9898b8;--vc-text-dim:#5a5a78;--vc-border:#262644;--vc-glow:0 0 40px rgba(99,102,241,.2);--r-sm:8px;--r-md:12px;--r-lg:16px;--r-xl:24px}
*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}
body{background:var(--vc-bg);color:var(--vc-text);font-family:'Chakra Petch',sans-serif;min-height:100vh;overflow-x:hidden}
.atmo{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 80% 60% at 15% 10%,rgba(99,102,241,.07) 0%,transparent 60%),radial-gradient(ellipse 70% 50% at 85% 90%,rgba(124,58,237,.06) 0%,transparent 55%)}
.hdr{position:fixed;top:0;left:0;right:0;z-index:100;height:58px;background:rgba(8,8,14,.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--vc-border);display:flex;align-items:center;padding:0 1.5rem;gap:1rem}
.logo{font-family:'Exo 2';font-weight:900;font-size:1.2rem;letter-spacing:3px;display:flex;align-items:center;gap:.4rem;cursor:pointer;flex-shrink:0}
.logo-i{width:30px;height:30px;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:900;color:#fff}
.logo-t{background:linear-gradient(135deg,var(--vc-primary-light),var(--vc-accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.logo-s{font-size:.55rem;font-weight:500;letter-spacing:2px;color:var(--vc-text-dim);-webkit-text-fill-color:var(--vc-text-dim)}
.nav{display:flex;gap:.2rem;margin-left:1rem}
.nb{background:0;border:0;color:var(--vc-text-secondary);font-family:'Chakra Petch';font-weight:600;font-size:.82rem;padding:.45rem .8rem;border-radius:var(--r-sm);cursor:pointer;transition:.25s}
.nb:hover{color:var(--vc-text);background:var(--vc-bg-surface)}.nb.on{color:var(--vc-primary-light);background:rgba(99,102,241,.1)}
.hdr-r{margin-left:auto;display:flex;align-items:center;gap:.7rem}
.wpill{display:flex;align-items:center;gap:.35rem;background:var(--vc-bg-surface);border:1px solid var(--vc-border);padding:.3rem .8rem;border-radius:50px;font-family:'JetBrains Mono';font-size:.78rem;color:var(--vc-gold);cursor:pointer;transition:.3s}
.wpill:hover{border-color:var(--vc-gold)}
.av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));display:flex;align-items:center;justify-content:center;font-family:'Exo 2';font-weight:800;font-size:.7rem;cursor:pointer}
.main{position:relative;z-index:1;padding-top:58px}.pg{display:none;animation:pi .3s ease}.pg.on{display:block}
@keyframes pi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
/* Shop */
.sh-hero{padding:2rem 2rem 1rem;text-align:center}
.sh-hero h1{font-family:'Exo 2';font-size:2rem;font-weight:900}.sh-hero .br{background:linear-gradient(135deg,var(--vc-primary-light),var(--vc-accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sh-hero p{color:var(--vc-text-secondary);font-size:.9rem;margin-top:.2rem}
.flt{display:flex;gap:.35rem;justify-content:center;padding:.4rem 2rem 1.2rem;flex-wrap:wrap}
.ch{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text-secondary);font-family:'Chakra Petch';font-weight:600;font-size:.8rem;padding:.3rem .9rem;border-radius:50px;cursor:pointer;transition:.25s}
.ch:hover{border-color:var(--vc-text-dim);color:var(--vc-text)}.ch.on{border-color:var(--vc-primary);color:var(--vc-primary-light);background:rgba(99,102,241,.08)}
.grd{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.2rem;padding:0 2rem 3rem;max-width:1440px;margin:0 auto}
.prd{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-lg);overflow:hidden;cursor:pointer;transition:.35s cubic-bezier(.23,1,.32,1);position:relative}
.prd:hover{transform:translateY(-5px);border-color:var(--vc-primary);box-shadow:var(--vc-glow)}
.prd-img{height:260px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.prd-bdg{position:absolute;top:8px;right:8px;font-weight:700;font-size:.6rem;padding:.18rem .5rem;border-radius:50px;text-transform:uppercase;letter-spacing:1.5px;z-index:2}
.prd-bdg.hot{background:var(--vc-fire);color:#fff}.prd-bdg.new{background:var(--vc-primary);color:#fff}.prd-bdg.ltd{background:var(--vc-secondary);color:#fff}
.prd-stk{position:absolute;top:8px;left:8px;background:rgba(8,8,14,.85);border:1px solid var(--vc-border);padding:.15rem .5rem;border-radius:50px;font-family:'JetBrains Mono';font-size:.6rem;color:var(--vc-text-secondary);z-index:2;display:flex;align-items:center;gap:.25rem}
.sd{width:5px;height:5px;border-radius:50%;background:var(--vc-green)}.sd.low{background:var(--vc-gold)}.sd.out{background:var(--vc-fire)}
.bv{width:100px;height:160px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;box-shadow:0 8px 35px rgba(0,0,0,.5);position:relative;z-index:1;transition:transform .5s cubic-bezier(.23,1,.32,1)}
.prd:hover .bv{transform:rotateY(6deg) rotateX(-3deg) scale(1.05)}
.prd-nfo{padding:.9rem 1rem;border-top:1px solid var(--vc-border)}
.prd-fr{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:var(--vc-text-dim);margin-bottom:.1rem}
.prd-nm{font-family:'Exo 2';font-weight:700;font-size:.9rem;margin-bottom:.1rem}
.prd-mt{color:var(--vc-text-secondary);font-size:.78rem;margin-bottom:.6rem}
.prd-ft{display:flex;justify-content:space-between;align-items:center}
.prd-pr{font-family:'JetBrains Mono';font-weight:700;font-size:1.1rem;color:var(--vc-gold)}
.qb{width:26px;height:26px;background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);border-radius:5px;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono';transition:.2s}
.qb:hover{background:var(--vc-bg-hover);border-color:var(--vc-primary)}
.qv{font-family:'JetBrains Mono';font-size:.8rem;width:22px;text-align:center}
.ob{background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border:0;font-family:'Exo 2';font-weight:700;font-size:.75rem;padding:.45rem 1rem;border-radius:var(--r-sm);cursor:pointer;transition:.3s;text-transform:uppercase;letter-spacing:1px}
.ob:hover{transform:scale(1.04);box-shadow:0 4px 18px rgba(99,102,241,.4)}
/* Overlay */
.ov{position:fixed;inset:0;z-index:200;background:rgba(4,4,8,.97);display:none;flex-direction:column;align-items:center;justify-content:center;overflow-y:auto;gap:.5rem;padding:1rem}.ov.open{display:flex}
.tear-s{position:relative;width:180px;height:280px;perspective:1200px}
.tear-p{width:100%;height:100%;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:3.5rem;cursor:pointer;position:relative;box-shadow:0 16px 70px rgba(99,102,241,.3);animation:pf 3s ease-in-out infinite}
@keyframes pf{0%,100%{transform:translateY(0) rotateY(-3deg)}50%{transform:translateY(-10px) rotateY(3deg)}}
.tear-p.tearing{animation:none}
.th{position:absolute;top:0;width:50%;height:100%;overflow:hidden;transition:.8s cubic-bezier(.68,-.55,.27,1.55)}
.th-l{left:0;border-radius:14px 0 0 14px;transform-origin:left center}.th-r{right:0;border-radius:0 14px 14px 0;transform-origin:right center}
.tear-p.torn .th-l{transform:rotateY(-45deg) translateX(-40px);opacity:0}.tear-p.torn .th-r{transform:rotateY(45deg) translateX(40px);opacity:0}
.ti{width:200%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3.5rem}.th-r .ti{margin-left:-100%}
.tg{position:absolute;inset:-20px;border-radius:30px;opacity:0;transition:opacity .5s;z-index:-1}.tear-p.tearing .tg{opacity:1;animation:gp .5s ease-in-out infinite}
@keyframes gp{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.1);opacity:1}}
.tt{font-family:'Exo 2';font-size:.95rem;font-weight:600;color:var(--vc-text-secondary);margin-top:1.2rem;animation:br 2s ease-in-out infinite}
@keyframes br{0%,100%{opacity:.4}50%{opacity:1}}
/* Stack — single card reveal */
.ss{display:none;position:relative;width:500px;max-width:92vw;height:380px;margin:0 auto;flex-shrink:0}.ss.on{display:block}
#stackC{position:relative;width:100%;height:100%}
.sc-pile-backs{position:absolute;left:50%;top:50%;width:220px;height:310px;margin-left:-110px;margin-top:-155px}
.sc-pile-back{position:absolute;inset:0;border-radius:var(--r-lg);background:linear-gradient(135deg,#0e0e22,#1a1a38);border:2px solid var(--vc-border);display:flex;align-items:center;justify-content:center;transition:all .3s ease}
.sc-pile-back:nth-child(2){top:3px;left:3px}
.sc-pile-back:nth-child(3){top:6px;left:6px}
.sc-active{position:absolute;left:50%;top:50%;width:240px;height:336px;margin-left:-120px;margin-top:-168px;border-radius:var(--r-lg);z-index:20;overflow:hidden;display:none}
.sc-active.on{display:block;animation:scReveal .5s ease forwards}
@keyframes scReveal{0%{opacity:0;transform:scale(.85)}100%{opacity:1;transform:scale(1)}}
.sc-active img.sc-card-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:var(--r-lg)}
.sc-active .sc-front-info{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(0deg,rgba(8,8,14,.95) 0%,rgba(8,8,14,.7) 50%,transparent 100%);padding:.7rem .8rem .6rem;z-index:5;border-radius:0 0 var(--r-lg) var(--r-lg)}
.sc-active .sc-front-name{font-family:'Exo 2';font-weight:700;font-size:.9rem;color:#fff;text-shadow:0 2px 6px rgba(0,0,0,.9)}
.sc-active .sc-front-val{font-family:'JetBrains Mono';font-size:.78rem;color:var(--vc-gold);font-weight:700;text-shadow:0 1px 4px rgba(0,0,0,.9)}
.sc-active .sc-front-rar{font-size:.6rem;text-transform:uppercase;letter-spacing:1.5px;font-weight:600;text-shadow:0 1px 4px rgba(0,0,0,.9);margin-top:.15rem}
.sc-bd{width:75%;height:75%;border:2px solid var(--vc-border);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.3rem}
.sc-bl{font-family:'Exo 2';font-weight:900;font-size:.85rem;letter-spacing:3px;background:linear-gradient(135deg,var(--vc-primary-light),var(--vc-accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sc-bs{font-size:.5rem;color:var(--vc-text-dim);letter-spacing:2px;text-transform:uppercase}
.sc-active.ry-common{border:1px solid var(--vc-border)}
.sc-active.ry-uncommon{border:1px solid rgba(52,211,153,.3);box-shadow:0 0 20px rgba(52,211,153,.15)}
.sc-active.ry-rare{border:2px solid rgba(59,130,246,.4);box-shadow:0 0 30px rgba(59,130,246,.2)}
.sc-active.ry-ultra{border:2px solid rgba(251,191,36,.5);box-shadow:0 0 40px rgba(251,191,36,.25)}
.sc-active.ry-secret{border:2px solid rgba(167,139,250,.6);box-shadow:0 0 55px rgba(167,139,250,.3);animation:sp 2s infinite}
@keyframes sp{0%,100%{box-shadow:0 0 35px rgba(167,139,250,.2)}50%{box-shadow:0 0 65px rgba(167,139,250,.4)}}
.rpile{position:absolute;right:10px;top:50%;transform:translateY(-50%);width:110px;height:155px}
.pc{position:absolute;width:110px;height:155px;border-radius:9px;overflow:hidden;box-shadow:0 2px 10px rgba(0,0,0,.4);transition:.4s cubic-bezier(.23,1,.32,1)}
.pc img{width:100%;height:100%;object-fit:cover;border-radius:9px}
.pcnt{position:absolute;bottom:-22px;left:50%;transform:translateX(-50%);font-family:'JetBrains Mono';font-size:.6rem;color:var(--vc-text-dim);white-space:nowrap}
.rstrip{display:none;gap:.4rem;padding:.5rem 1rem;max-width:90vw;overflow-x:auto;justify-content:center;flex-wrap:wrap;max-height:140px}.rstrip.on{display:flex}
.stc{width:56px;height:78px;border-radius:7px;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;text-align:center;flex-shrink:0;animation:si .4s cubic-bezier(.23,1,.32,1);border:1px solid var(--vc-border);position:relative;overflow:hidden}
.stc img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:7px;opacity:.8}
.stc-lb{position:relative;z-index:1;background:linear-gradient(transparent,rgba(8,8,14,.9));width:100%;padding:.1rem;border-radius:0 0 7px 7px}
.stc-n{font-size:.35rem;font-weight:600;line-height:1.1}.stc-v{font-family:'JetBrains Mono';font-size:.35rem;color:var(--vc-text-dim)}
.stc.s-common{background:var(--vc-bg-surface)}.stc.s-uncommon{background:linear-gradient(135deg,#0a1a15,#0f2a1f);border-color:rgba(52,211,153,.25)}
.stc.s-rare{background:linear-gradient(135deg,#0a0f1a,#0f1a2f);border-color:rgba(59,130,246,.35)}
.stc.s-ultra{background:linear-gradient(135deg,#1a150a,#2a1f0f);border-color:rgba(251,191,36,.35)}
.stc.s-secret{background:linear-gradient(135deg,#1a0a2a,#2a0f3a);border-color:rgba(167,139,250,.4)}
@keyframes si{from{transform:scale(0) translateY(-15px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
.rc{display:none;gap:.5rem;margin-top:1rem;flex-wrap:wrap;justify-content:center}.rc.on{display:flex}
.rb{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'Chakra Petch';font-weight:600;font-size:.82rem;padding:.5rem 1.1rem;border-radius:var(--r-sm);cursor:pointer;transition:.25s;display:flex;align-items:center;gap:.35rem}
.rb:hover{border-color:var(--vc-primary);background:var(--vc-bg-hover);transform:translateY(-1px)}
.rb.pri{background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));border:0;color:#fff}.rb.pri:hover{box-shadow:0 4px 18px rgba(99,102,241,.4)}
.sctr{text-align:center;font-family:'JetBrains Mono';font-size:.78rem;color:var(--vc-text-secondary);background:rgba(8,8,14,.8);padding:.25rem .7rem;border-radius:50px;border:1px solid var(--vc-border);margin-top:.4rem}
/* Collection */
.coll-hd{padding:2rem 2rem .8rem;max-width:1440px;margin:0 auto}
.coll-hd h1{font-family:'Exo 2';font-weight:900;font-size:1.7rem}
.coll-hd-sub{color:var(--vc-text-secondary);font-size:.85rem;margin-top:.15rem}
.coll-tb{display:flex;justify-content:space-between;align-items:center;padding:.6rem 2rem;max-width:1440px;margin:0 auto;flex-wrap:wrap;gap:.4rem}
.csts{display:flex;gap:1.3rem}
.csv{font-family:'JetBrains Mono';font-weight:700;font-size:1.1rem;color:var(--vc-primary-light)}
.csl{font-size:.65rem;color:var(--vc-text-dim);text-transform:uppercase;letter-spacing:1.5px}
.cacts{display:flex;gap:.35rem;flex-wrap:wrap}
.cb{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text-secondary);font-family:'Chakra Petch';font-weight:600;font-size:.75rem;padding:.35rem .7rem;border-radius:var(--r-sm);cursor:pointer;transition:.25s}
.cb:hover{border-color:var(--vc-primary);color:var(--vc-text)}.cb.on{border-color:var(--vc-primary);color:var(--vc-primary-light);background:rgba(99,102,241,.08)}
.coll-bd{padding:.8rem 2rem 3rem;max-width:1440px;margin:0 auto}
.set-blk{margin-bottom:2rem}
.set-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:.7rem;flex-wrap:wrap;gap:.4rem}
.set-tt{font-family:'Exo 2';font-weight:700;font-size:.95rem}
.set-pr{display:flex;align-items:center;gap:.5rem}
.pb{width:120px;height:5px;background:var(--vc-bg-surface);border-radius:3px;overflow:hidden}
.pbf{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--vc-primary),var(--vc-accent));transition:width .5s}
.pbt{font-family:'JetBrains Mono';font-size:.65rem;color:var(--vc-text-secondary)}
.cgrd{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:.7rem}
.cc{aspect-ratio:5/7;background:var(--vc-bg-surface);border:1px solid var(--vc-border);border-radius:var(--r-md);display:flex;flex-direction:column;align-items:center;justify-content:flex-end;cursor:pointer;transition:.3s;position:relative;overflow:hidden}
.cc:hover{transform:translateY(-3px);border-color:var(--vc-primary)}
.cc img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:var(--r-md)}
.cc-lb{position:relative;z-index:1;margin-top:auto;background:linear-gradient(transparent,rgba(8,8,14,.95));width:100%;padding:.35rem .4rem;text-align:center;border-radius:0 0 var(--r-md) var(--r-md)}
.cc-nm{font-size:.65rem;font-weight:600}.cc-vl{font-family:'JetBrains Mono';font-size:.6rem;color:var(--vc-gold);font-weight:700}
.rd{position:absolute;top:5px;left:5px;width:6px;height:6px;border-radius:50%;z-index:2}
.rd-common{background:#666}.rd-uncommon{background:var(--vc-green);box-shadow:0 0 5px var(--vc-green)}.rd-rare{background:var(--vc-blue);box-shadow:0 0 7px var(--vc-blue)}.rd-ultra{background:var(--vc-gold);box-shadow:0 0 9px var(--vc-gold)}.rd-secret{background:var(--vc-accent);box-shadow:0 0 11px var(--vc-accent)}
.copies-badge{position:absolute;top:4px;right:4px;background:rgba(99,102,241,.92);color:#fff;font-family:'JetBrains Mono';font-size:.55rem;font-weight:700;padding:.12rem .4rem;border-radius:4px;z-index:3}
/* Card Detail Modal */
.cdm{position:fixed;inset:0;z-index:300;background:rgba(4,4,8,.92);backdrop-filter:blur(12px);display:none;align-items:center;justify-content:center;padding:1rem}.cdm.on{display:flex}
.cdm-inner{display:flex;gap:2rem;max-width:750px;width:95%;animation:mi .3s ease}
@keyframes mi{from{opacity:0;transform:scale(.96) translateY(12px)}to{opacity:1;transform:scale(1) translateY(0)}}
.cdm-img{width:260px;flex-shrink:0;border-radius:var(--r-lg);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5);position:relative}
.cdm-img img{width:100%;height:auto;display:block}
.cdm-nav{display:flex;justify-content:space-between;margin-top:.5rem;gap:.3rem}
.cdm-nav-btn{flex:1;background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);padding:.35rem;border-radius:var(--r-sm);cursor:pointer;font-size:.85rem;transition:.2s;text-align:center}
.cdm-nav-btn:hover:not(:disabled){border-color:var(--vc-primary);background:var(--vc-bg-hover)}
.cdm-nav-btn:disabled{opacity:.3;cursor:default}
.cdm-nav-lbl{text-align:center;font-family:'JetBrains Mono';font-size:.6rem;color:var(--vc-text-dim);margin-top:.2rem}
.cdm-info{flex:1;display:flex;flex-direction:column;gap:.6rem;overflow-y:auto;max-height:80vh}
.cdm-name{font-family:'Exo 2';font-weight:800;font-size:1.3rem}
.cdm-rar{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:2px}
.cdm-val{font-family:'JetBrains Mono';font-size:1.1rem;color:var(--vc-gold)}
.cdm-meta{display:flex;flex-direction:column;gap:.35rem}
.cdm-row{display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--vc-text-secondary)}
.cdm-row span{color:var(--vc-text);font-weight:600}
.cdm-acts{display:flex;flex-direction:column;gap:.3rem;margin-top:.5rem}
.cdm-btn{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'Chakra Petch';font-weight:600;font-size:.8rem;padding:.45rem .8rem;border-radius:var(--r-sm);cursor:pointer;transition:.25s;text-align:left;display:flex;align-items:center;gap:.5rem}
.cdm-btn:hover{border-color:var(--vc-primary);background:var(--vc-bg-hover)}
.cdm-x{position:absolute;top:1rem;right:1.5rem;background:0;border:0;color:var(--vc-text-dim);font-size:1.5rem;cursor:pointer;transition:.2s;z-index:2}.cdm-x:hover{color:var(--vc-text)}
/* Binder */
.binder{display:none;max-width:900px;margin:0 auto}.binder.on{display:block}
.bb{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-xl);overflow:hidden}
.bn{display:flex;justify-content:space-between;align-items:center;padding:.8rem 1.2rem;border-bottom:1px solid var(--vc-border);flex-wrap:wrap;gap:.4rem}
.bn-stats{font-family:'JetBrains Mono';font-size:.7rem;color:var(--vc-text-secondary);display:flex;align-items:center;gap:.5rem}
.bn-pct{color:var(--vc-primary-light);font-weight:700}
.bp{display:grid;grid-template-columns:1fr 1px 1fr;min-height:450px}
.bsp{background:var(--vc-border)}.bpg{padding:1rem}
.bpgrd{display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(3,1fr);gap:.5rem;height:100%}
.bsl{background:var(--vc-bg-surface);border:1px dashed var(--vc-border);border-radius:var(--r-sm);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;position:relative;overflow:hidden;min-height:0;aspect-ratio:5/7;cursor:pointer;transition:.3s}
.bsl.filled{border-style:solid}.bsl.filled:hover{border-color:var(--vc-primary);transform:scale(1.03)}
.bsl img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:var(--r-sm)}
.bsl .bsn{position:absolute;top:2px;left:4px;font-family:'JetBrains Mono';font-size:.45rem;color:var(--vc-text-dim);z-index:1;text-shadow:0 1px 2px rgba(0,0,0,.8)}
.bsl .bse{font-size:1.3rem}.bsl .bsnm{font-size:.45rem;font-weight:600}
.bsl.empty{opacity:.25}
.bsl .copies-badge{top:auto;bottom:3px;right:3px;left:auto}
.ba{display:flex;gap:.25rem}
.bar{width:28px;height:28px;background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);border-radius:5px;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;transition:.2s}
.bar:hover{background:var(--vc-bg-hover);border-color:var(--vc-primary)}
/* Marketplace */
.mkt{max-width:1440px;margin:0 auto;padding:2rem 2rem 3rem}
.mkt h1{font-family:'Exo 2';font-weight:900;font-size:1.7rem}
.mkt>p{color:var(--vc-text-secondary);margin:.2rem 0 1rem;font-size:.88rem}
.mkt-info{background:rgba(99,102,241,.06);border:1px solid var(--vc-border);border-radius:var(--r-md);padding:.7rem .9rem;margin-bottom:1rem;font-size:.82rem;color:var(--vc-text-secondary);display:flex;align-items:center;gap:.5rem}
.mkt-filters{display:flex;gap:.3rem;margin-bottom:.5rem;flex-wrap:wrap;align-items:center}
.mkt-filters select{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);padding:.3rem .5rem;border-radius:var(--r-sm);font-family:'Chakra Petch';font-size:.78rem;cursor:pointer;transition:.2s}
.mkt-filters select:hover{border-color:var(--vc-primary)}
.mkt-filters label{font-size:.7rem;color:var(--vc-text-dim);margin-right:.15rem}
.mkt-featured{margin-bottom:1.5rem}
.mkt-featured-title{font-family:'Exo 2';font-weight:700;font-size:.9rem;margin-bottom:.7rem;display:flex;align-items:center;gap:.4rem;color:var(--vc-gold)}
.mkgrd{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1rem}
.mk{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-md);padding:.8rem;transition:.3s;cursor:pointer}
.mk:hover{transform:translateY(-3px);border-color:var(--vc-primary);box-shadow:var(--vc-glow)}
.mk.featured{border-color:rgba(251,191,36,.3);background:linear-gradient(135deg,rgba(251,191,36,.03),var(--vc-bg-card))}
.mk-top{display:flex;justify-content:space-between;margin-bottom:.2rem}
.mk-slr{font-size:.65rem;color:var(--vc-text-dim)}
.mk-date{font-size:.55rem;color:var(--vc-text-dim);font-family:'JetBrains Mono'}
.mk-vis{width:100%;aspect-ratio:5/7;background:var(--vc-bg-surface);border-radius:7px;overflow:hidden;margin-bottom:.5rem}
.mk-vis img{width:100%;height:100%;object-fit:cover}
.mk-nm{font-weight:700;font-size:.85rem}.mk-set{font-size:.65rem;color:var(--vc-text-dim);margin-bottom:.15rem}
.mk-ref{font-size:.55rem;color:var(--vc-text-dim);font-family:'JetBrains Mono';margin-bottom:.4rem}
.mk-ft{display:flex;justify-content:space-between;align-items:center}
.mk-pr{font-family:'JetBrains Mono';font-weight:700;color:var(--vc-green)}
.mk-pr-old{text-decoration:line-through;color:var(--vc-text-dim);font-size:.75rem;margin-right:.3rem}
.mk-buy{background:var(--vc-bg-elevated);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'Chakra Petch';font-weight:600;font-size:.75rem;padding:.3rem .6rem;border-radius:5px;cursor:pointer;transition:.25s}
.mk-buy:hover{background:var(--vc-primary);color:#fff;border-color:var(--vc-primary)}
.mk-nego-hist{margin-top:.3rem;font-size:.6rem;color:var(--vc-fire);font-style:italic}
/* Wallet */
.ww{max-width:560px;margin:0 auto;padding:2rem 2rem 3rem}
.ww h1{font-family:'Exo 2';font-weight:900;font-size:1.7rem;text-align:center;margin-bottom:1.3rem}
.bc{background:linear-gradient(135deg,rgba(99,102,241,.12),rgba(124,58,237,.08));border:1px solid var(--vc-border);border-radius:var(--r-xl);padding:1.8rem;text-align:center;margin-bottom:1.3rem}
.bc-l{font-size:.7rem;text-transform:uppercase;letter-spacing:3px;color:var(--vc-text-secondary);margin-bottom:.2rem}
.bc-a{font-family:'JetBrains Mono';font-weight:700;font-size:2.5rem;color:var(--vc-gold)}
.bc-a .cu{font-size:1.2rem;opacity:.7}
.ds{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-lg);padding:1.2rem;margin-bottom:1rem}
.ds h3{font-family:'Exo 2';font-weight:700;font-size:.9rem;margin-bottom:.7rem}
.dch{display:grid;grid-template-columns:repeat(4,1fr);gap:.35rem;margin-bottom:.7rem}
.dc{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'JetBrains Mono';font-size:.82rem;padding:.5rem;border-radius:var(--r-sm);cursor:pointer;transition:.25s;text-align:center}
.dc:hover,.dc.sel{border-color:var(--vc-primary);background:rgba(99,102,241,.1);color:var(--vc-primary-light)}
.dc-custom{font-family:'Chakra Petch';font-size:.78rem}
.dc-input{display:none;margin-bottom:.7rem}.dc-input.on{display:block}
.dc-input input{width:100%;background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'JetBrains Mono';font-size:.9rem;padding:.5rem .8rem;border-radius:var(--r-sm);outline:0}
.dc-input input:focus{border-color:var(--vc-primary)}
.dbtn{width:100%;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border:0;font-family:'Exo 2';font-weight:700;font-size:.95rem;padding:.7rem;border-radius:var(--r-sm);cursor:pointer;transition:.3s;text-transform:uppercase;letter-spacing:2px}
.dbtn:hover{transform:translateY(-1px);box-shadow:0 5px 20px rgba(99,102,241,.35)}
.txs{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-lg);padding:1.2rem}
.txs h3{font-family:'Exo 2';font-weight:700;font-size:.9rem;margin-bottom:.7rem}
.txi{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--vc-border)}.txi:last-child{border-bottom:0}
.txl{display:flex;align-items:center;gap:.5rem}
.txic{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.8rem}
.txic.dep{background:rgba(52,211,153,.12)}.txic.pur{background:rgba(239,68,68,.12)}.txic.sale{background:rgba(99,102,241,.12)}.txic.rec{background:rgba(34,211,238,.12)}
.txd{font-weight:500;font-size:.82rem}.txdt{font-size:.6rem;color:var(--vc-text-dim)}
.txa{font-family:'JetBrains Mono';font-weight:700;font-size:.82rem}.txa.pos{color:var(--vc-green)}.txa.neg{color:var(--vc-fire)}
.tx-nav{display:flex;justify-content:center;align-items:center;gap:.5rem;margin-top:.7rem}
.tx-nav-btn{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text-secondary);width:28px;height:28px;border-radius:5px;cursor:pointer;font-size:.8rem;display:flex;align-items:center;justify-content:center;transition:.2s}
.tx-nav-btn:hover{border-color:var(--vc-primary);color:var(--vc-text)}.tx-nav-btn:disabled{opacity:.3;cursor:default}
.tx-nav-pg{font-family:'JetBrains Mono';font-size:.7rem;color:var(--vc-text-dim)}
/* Modals */
.mbg{position:fixed;inset:0;background:rgba(4,4,8,.85);backdrop-filter:blur(12px);z-index:300;display:none;align-items:center;justify-content:center}.mbg.on{display:flex}
.mod{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-xl);padding:1.6rem;max-width:420px;width:92%;animation:mi .3s ease}
.mod h2{font-family:'Exo 2';font-weight:700;font-size:1.05rem;margin-bottom:.7rem}
.mx{float:right;background:0;border:0;color:var(--vc-text-dim);font-size:1.2rem;cursor:pointer}.mx:hover{color:var(--vc-text)}
.mi{width:100%;background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'Chakra Petch';font-size:.9rem;padding:.55rem .8rem;border-radius:var(--r-sm);margin-bottom:.5rem;outline:0}.mi:focus{border-color:var(--vc-primary)}
.mr{display:flex;justify-content:flex-end;gap:.4rem;margin-top:.7rem}
.mn{font-size:.75rem;color:var(--vc-text-dim);margin:.4rem 0}
.toast{position:fixed;bottom:1.3rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--vc-bg-elevated);border:1px solid var(--vc-border);border-radius:var(--r-md);padding:.7rem 1.2rem;z-index:500;display:flex;align-items:center;gap:.5rem;transition:.4s cubic-bezier(.23,1,.32,1);box-shadow:0 10px 35px rgba(0,0,0,.5);font-weight:500;font-size:.85rem}
.toast.on{transform:translateX(-50%) translateY(0)}.toast.ok{border-color:var(--vc-green)}.toast.err{border-color:var(--vc-fire)}
.ptcl-box{position:fixed;inset:0;pointer-events:none;z-index:199}
.ptcl{position:absolute;border-radius:50%;animation:ptf 1.2s ease-out forwards}
@keyframes ptf{0%{transform:translate(0,0) scale(1);opacity:1}100%{transform:translate(var(--px),var(--py)) scale(0);opacity:0}}
.mnav{display:none;position:fixed;bottom:0;left:0;right:0;background:rgba(8,8,14,.95);backdrop-filter:blur(20px);border-top:1px solid var(--vc-border);z-index:100;padding:.35rem .2rem;justify-content:space-around}
@media(max-width:768px){.mnav{display:flex}.nav{display:none}.main{padding-bottom:62px}.grd{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));padding:0 1rem 2rem}.bp{grid-template-columns:1fr}.bsp{display:none}.dch{grid-template-columns:repeat(2,1fr)}.coll-tb{flex-direction:column;align-items:flex-start}.cdm-inner{flex-direction:column;align-items:center}.cdm-img{width:180px}}
.mb{background:0;border:0;color:var(--vc-text-dim);font-family:'Chakra Petch';font-size:.55rem;font-weight:600;display:flex;flex-direction:column;align-items:center;gap:.1rem;cursor:pointer;padding:.15rem .5rem}
.mb .ico{font-size:1.1rem}.mb.on{color:var(--vc-primary-light)}
.empty{text-align:center;color:var(--vc-text-dim);padding:3rem 0}
.empty .ei{font-size:2.5rem;margin-bottom:.6rem}.empty .et{font-size:1rem;font-weight:600;color:var(--vc-text-secondary)}.empty .es{font-size:.82rem;margin-top:.15rem}
.um-i{display:flex;align-items:center;gap:.5rem;padding:.55rem 1rem;font-size:.8rem;color:var(--vc-text-secondary);cursor:pointer;transition:.15s;font-weight:500}.um-i:hover{background:var(--vc-bg-hover);color:var(--vc-text)}
.auth-form{display:none}.auth-form.on{display:block}
.auth-tab.on{color:var(--vc-primary-light)!important;border-bottom-color:var(--vc-primary)!important}
/* Profile */
.prof{max-width:700px;margin:0 auto;padding:2rem}
.prof h1{font-family:'Exo 2';font-weight:900;font-size:1.7rem;margin-bottom:1.5rem}
.prof-card{background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:var(--r-xl);padding:1.5rem;margin-bottom:1rem}
.prof-top{display:flex;align-items:center;gap:1.2rem;margin-bottom:1rem}
.prof-av{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));display:flex;align-items:center;justify-content:center;font-family:'Exo 2';font-weight:900;font-size:1.5rem;color:#fff;flex-shrink:0;cursor:pointer;transition:.3s;position:relative;overflow:hidden}
.prof-av:hover{box-shadow:0 0 20px rgba(99,102,241,.4);transform:scale(1.05)}
.prof-av img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.prof-uname{font-family:'Exo 2';font-weight:800;font-size:1.3rem}
.prof-email{font-size:.75rem;color:var(--vc-text-dim)}
.prof-lvl{display:flex;align-items:center;gap:.5rem;margin-top:.3rem}
.prof-lvl-badge{background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;font-family:'JetBrains Mono';font-size:.65rem;font-weight:700;padding:.2rem .5rem;border-radius:4px}
.prof-xp{font-family:'JetBrains Mono';font-size:.65rem;color:var(--vc-text-secondary)}
.prof-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin-bottom:1rem}
.prof-stat{background:var(--vc-bg-surface);border:1px solid var(--vc-border);border-radius:var(--r-md);padding:1rem;text-align:center}
.prof-stat-val{font-family:'JetBrains Mono';font-weight:700;font-size:1.3rem;color:var(--vc-primary-light)}
.prof-stat-lbl{font-size:.65rem;color:var(--vc-text-dim);text-transform:uppercase;letter-spacing:1.5px;margin-top:.2rem}
.prof-section{margin-bottom:1rem}
.prof-section h3{font-family:'Exo 2';font-weight:700;font-size:.9rem;margin-bottom:.6rem}
.prof-row{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid var(--vc-border)}
.prof-row:last-child{border-bottom:0}
.prof-row label{font-size:.8rem;color:var(--vc-text-secondary)}
.prof-row span{font-size:.8rem;font-weight:600}
.prof-input{background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);font-family:'Chakra Petch';font-size:.82rem;padding:.4rem .7rem;border-radius:var(--r-sm);outline:0;width:200px}.prof-input:focus{border-color:var(--vc-primary)}
.prof-btn{background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border:0;font-family:'Chakra Petch';font-weight:600;font-size:.8rem;padding:.5rem 1rem;border-radius:var(--r-sm);cursor:pointer;transition:.3s}.prof-btn:hover{filter:brightness(1.15);transform:translateY(-1px)}
.prof-btn-danger{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#ef4444}
.prof-btn-danger:hover{background:rgba(239,68,68,.25)}
.prof-avatars{display:flex;gap:.5rem;flex-wrap:wrap;margin:.5rem 0}
.prof-avatar-opt{width:48px;height:48px;border-radius:50%;cursor:pointer;border:2px solid var(--vc-border);transition:.2s;display:flex;align-items:center;justify-content:center;font-size:1.5rem;background:var(--vc-bg-surface)}
.prof-avatar-opt:hover,.prof-avatar-opt.sel{border-color:var(--vc-primary);box-shadow:0 0 12px rgba(99,102,241,.3)}
/* Card Detail Actions */
.cdm-act{display:flex;align-items:center;gap:.4rem;padding:.45rem .6rem;border-radius:8px;border:1px solid var(--vc-border);background:var(--vc-bg-surface);color:var(--vc-text);font-family:'Chakra Petch';font-size:.72rem;font-weight:600;cursor:pointer;transition:.2s;white-space:nowrap;overflow:hidden}
.cdm-act:hover{filter:brightness(1.2);transform:translateY(-1px)}
.cdm-act-i{font-size:.85rem;flex-shrink:0}
.cdm-act.sell,.cdm-act.sell-m{border-color:rgba(52,211,153,.25);color:var(--vc-green)}
.cdm-act.sell:hover,.cdm-act.sell-m:hover{background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.4)}
.cdm-act.rec,.cdm-act.rec-m{border-color:rgba(34,211,238,.25);color:var(--vc-cyan)}
.cdm-act.rec:hover,.cdm-act.rec-m:hover{background:rgba(34,211,238,.08);border-color:rgba(34,211,238,.4)}
.cdm-act.ship,.cdm-act.ship-m{border-color:rgba(251,191,36,.25);color:var(--vc-gold)}
.cdm-act.ship:hover,.cdm-act.ship-m:hover{background:rgba(251,191,36,.08);border-color:rgba(251,191,36,.4)}
.cdm-act.ship.on{background:rgba(251,191,36,.12);border-color:rgba(251,191,36,.5);color:var(--vc-gold)}
.cdm-act.sell-m,.cdm-act.rec-m,.cdm-act.ship-m{opacity:.75;font-size:.68rem}
.cdm-close{display:block;width:auto;margin:.5rem auto 0;padding:.35rem 2rem;border-radius:6px;border:1px solid var(--vc-border);background:transparent;color:var(--vc-text-dim);font-family:'Chakra Petch';font-size:.7rem;font-weight:500;cursor:pointer;transition:.2s;letter-spacing:.5px}
.cdm-close:hover{background:var(--vc-bg-hover);color:var(--vc-text)}
</style>
</head>
<body>
<div class="atmo"></div>
<header class="hdr">
  <div class="logo" onclick="go('shop')"><div class="logo-i">V</div><div><div class="logo-t">VAULTA</div><div class="logo-s">CLUB</div></div></div>
  <nav class="nav"><button class="nb on" data-p="shop" onclick="go('shop')">Boutique</button><button class="nb" data-p="coll" onclick="go('coll')">Collection</button><button class="nb" data-p="mkt" onclick="go('mkt')">Marché</button><button class="nb" data-p="wal" onclick="go('wal')">Portefeuille</button></nav>
  <div class="hdr-r">
    <div class="wpill" onclick="go('wal')" id="hBalPill" style="display:none">💎 <span id="hBal">0.00€</span></div>
    <div class="av" id="avBtn" onclick="toggleUserMenu()" style="position:relative">
      <span id="avText">?</span>
      <div id="userMenu" style="position:absolute;top:calc(100% + 8px);right:0;background:var(--vc-bg-card);border:1px solid var(--vc-border);border-radius:12px;padding:.4rem 0;min-width:200px;box-shadow:0 12px 40px rgba(0,0,0,.5);z-index:200;display:none">
        <div style="padding:.7rem 1rem;border-bottom:1px solid var(--vc-border)"><div style="font-weight:700;font-size:.85rem" id="umName">—</div><div style="font-size:.65rem;color:var(--vc-text-dim);margin-top:.1rem" id="umEmail">—</div><div style="font-size:.65rem;color:var(--vc-primary-light);font-weight:600;margin-top:.2rem" id="umLvl">Niveau 1</div></div>
        <div class="um-i" onclick="event.stopPropagation();go('prof');closeUM()">👤 Mon Profil</div>
        <div class="um-i" onclick="event.stopPropagation();go('wal');closeUM()">💎 Portefeuille</div>
        <div class="um-i" onclick="event.stopPropagation();go('coll');closeUM()">📁 Ma Collection</div>
        <div style="height:1px;background:var(--vc-border);margin:.3rem 0"></div>
        <div class="um-i" style="color:#ef4444" onclick="event.stopPropagation();doLogout()">🚪 Déconnexion</div>
      </div>
    </div>
  </div>
</header>
<main class="main">
<div class="pg on" id="p-shop">
  <div class="sh-hero"><h1>Ouvre ton <span class="br">Destin</span></h1><p>De vrais boosters scannés — chaque carte est physique & unique</p></div>
  <div class="flt"><button class="ch on" onclick="filt('all',this)">Tous</button><button class="ch" onclick="filt('pokemon',this)">Pokémon</button></div>
  <div class="grd" id="shopG"></div>
</div>
<div class="pg" id="p-coll">
  <div class="coll-hd"><h1>Ma Collection</h1><div class="coll-hd-sub">Votre classeur virtuel — vos cartes physiques en sécurité</div></div>
  <div class="coll-tb">
    <div class="csts"><div><div class="csv" id="cTot">0</div><div class="csl">Cartes</div></div><div><div class="csv" id="cVal">0.00€</div><div class="csl">Valeur</div></div></div>
    <div class="cacts">
      <button class="cb on" id="vGrid" onclick="setCV('grid')">☷ Grille</button>
      <button class="cb" id="vBind" onclick="setCV('binder')">📖 Classeur</button>
      <button class="cb" onclick="bulkRecycle()">♻️ Tout recycler</button>
      <button class="cb" onclick="bulkShip()">📦 Tout recevoir</button>
      <button class="cb" id="shipCartBtn" onclick="openShipCartM()" style="display:none">📦 Panier (0)</button>
    </div>
  </div>
  <div class="coll-bd"><div id="collG"></div><div class="binder" id="collB"></div></div>
</div>
<div class="pg" id="p-mkt">
  <div class="mkt">
    <h1>Marché</h1>
    <p>Achetez & vendez entre collectionneurs — Commission : 8%</p>
    <div class="mkt-info">ℹ️ Commission de 8% sur chaque vente. Négociations possibles entre acheteurs et vendeurs.</div>
    <div class="mkt-filters" id="mktFilters"></div>
    <div class="mkt-featured" id="mktFeat"></div>
    <div class="mkgrd" id="mktG"></div>
  </div>
</div>
<div class="pg" id="p-wal">
  <div class="ww">
    <h1>Portefeuille</h1>
    <div class="bc"><div class="bc-l">Solde disponible</div><div class="bc-a"><span class="cu">€ </span><span id="wBal">0.00</span></div></div>
    <div class="ds"><h3>Ajouter des fonds</h3>
      <div class="dch"><button class="dc sel" onclick="selD(10,this)">10€</button><button class="dc" onclick="selD(25,this)">25€</button><button class="dc" onclick="selD(50,this)">50€</button><button class="dc dc-custom" onclick="selD(-1,this)">Autre</button></div>
      <div class="dc-input" id="customDep"><input type="number" min="1" placeholder="Montant en €" id="customAmt"></div>
      <button class="dbtn" id="depBtn" onclick="deposit()">Déposer 10€</button>
    </div>
    <div class="txs"><h3>Historique</h3><div id="txList"></div><div class="tx-nav" id="txNav"></div></div>
  </div>
</div>
<!-- PROFILE -->
<div class="pg" id="p-prof">
  <div class="prof">
    <h1>Mon Profil</h1>
    <div class="prof-card">
      <div class="prof-top">
        <div class="prof-av" id="profAv" onclick="document.getElementById('avatarPicker').style.display=document.getElementById('avatarPicker').style.display==='none'?'block':'none'">?</div>
        <div>
          <div class="prof-uname" id="profName">—</div>
          <div class="prof-email" id="profEmail">—</div>
          <div class="prof-lvl">
            <span class="prof-lvl-badge" id="profLvlBadge">Niv. 1</span>
            <span class="prof-xp" id="profXP">0 XP</span>
          </div>
        </div>
      </div>
      <div id="avatarPicker" style="display:none;margin-bottom:.8rem">
        <p style="font-size:.75rem;color:var(--vc-text-secondary);margin-bottom:.4rem">Choisir un avatar :</p>
        <div class="prof-avatars" id="avatarGrid"></div>
      </div>
    </div>
    <div class="prof-stats">
      <div class="prof-stat"><div class="prof-stat-val" id="profCards">0</div><div class="prof-stat-lbl">Cartes</div></div>
      <div class="prof-stat"><div class="prof-stat-val" id="profValue">0€</div><div class="prof-stat-lbl">Valeur</div></div>
      <div class="prof-stat"><div class="prof-stat-val" id="profBoosters">0</div><div class="prof-stat-lbl">Boosters ouverts</div></div>
    </div>
    <div class="prof-card prof-section">
      <h3>⚙️ Informations du compte</h3>
      <div class="prof-row"><label>Pseudo</label><input class="prof-input" id="profEditName" placeholder="Pseudo"></div>
      <div class="prof-row"><label>Email</label><span id="profEditEmail" style="font-size:.8rem;color:var(--vc-text-dim)">—</span></div>
      <div class="prof-row"><label>Membre depuis</label><span id="profJoined" style="font-size:.8rem">—</span></div>
      <div style="display:flex;gap:.5rem;margin-top:.7rem">
        <button class="prof-btn" onclick="saveProfile()">💾 Sauvegarder</button>
      </div>
    </div>
    <div class="prof-card prof-section">
      <h3>📊 Historique récent</h3>
      <div id="profHistory"></div>
    </div>
    <div class="prof-card prof-section">
      <h3>🔐 Sécurité</h3>
      <div class="prof-row"><label>Mot de passe</label><button class="prof-btn" style="font-size:.75rem;padding:.35rem .7rem" onclick="toast('Fonctionnalité bientôt disponible','ok')">Modifier</button></div>
      <div style="margin-top:.7rem">
        <button class="prof-btn prof-btn-danger" onclick="doLogout()">🚪 Se déconnecter</button>
      </div>
    </div>
  </div>
</div>
</main>
<nav class="mnav"><button class="mb on" data-p="shop" onclick="go('shop')"><span class="ico">🛒</span>Boutique</button><button class="mb" data-p="coll" onclick="go('coll')"><span class="ico">📁</span>Collection</button><button class="mb" data-p="mkt" onclick="go('mkt')"><span class="ico">💱</span>Marché</button><button class="mb" data-p="wal" onclick="go('wal')"><span class="ico">💰</span>Wallet</button></nav>
<!-- Overlay -->
<div class="ov" id="overlay">
  <div id="boosterBadge" style="position:absolute;top:12px;left:50%;transform:translateX(-50%);z-index:10;background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.3);padding:.3rem .9rem;border-radius:50px;font-family:'JetBrains Mono';font-size:.75rem;color:var(--vc-primary-light);display:none"></div>
  <div class="tear-s" id="tearS"><div class="tear-p" id="tearP" onclick="tear()"><div class="tg" id="tearG"></div><div class="th th-l"><div class="ti" id="tiL"></div></div><div class="th th-r"><div class="ti" id="tiR"></div></div></div></div>
  <div class="tt" id="tearT">Cliquez pour déchirer le booster</div>
  <div class="ss" id="stackS"><div id="stackC"></div><div class="rpile" id="rPile"><div class="pcnt" id="pCnt"></div></div></div>
  <div class="sctr" id="sCtr" style="display:none"></div>
  <div class="rstrip" id="rStrip"></div>
  <div class="rc" id="revC">
    <button class="rb" id="bNext" onclick="revNext()">👆 Carte suivante</button>
    <button class="rb" id="bAuto" onclick="startAuto()">⚡ Ouverture auto</button>
    <button class="rb" id="bSkip" onclick="skipEnd()" style="display:none">⏩ Passer</button>
    <button class="rb pri" id="bStore" onclick="storeAll()" style="display:none">📁 Stocker & Fermer</button>
  </div>
</div>
<div class="ptcl-box" id="ptclB"></div>
<!-- Card Detail -->
<div class="cdm" id="cardDetail">
  <button class="cdm-x" onclick="closeCD()">×</button>
  <div class="cdm-inner">
    <div class="cdm-img" id="cdImg"></div>
    <div class="cdm-info">
      <div class="cdm-name" id="cdName"></div>
      <div class="cdm-rar" id="cdRar"></div>
      <div class="cdm-val" id="cdVal"></div>
      <div class="cdm-meta" id="cdMeta"></div>
      <div class="cdm-acts" id="cdActs"></div>
    </div>
  </div>
</div>
<!-- Sell Modal -->
<div class="mbg" id="sellM"><div class="mod"><button class="mx" onclick="cMod('sellM')">×</button><h2>💱 Placer sur le Marché</h2><p class="mn">Commission de 8% prélevée lors de la vente.</p><div style="display:flex;align-items:center;gap:.7rem;margin:.6rem 0"><span id="smE" style="font-size:1.8rem"></span><div><div id="smN" style="font-weight:700"></div><div id="smR" style="font-size:.7rem;color:var(--vc-text-dim)"></div></div></div><label style="font-size:.75rem;color:var(--vc-text-secondary)">Prix de vente (€)</label><input class="mi" id="smP" type="number" step="0.01" min="0.01" placeholder="Ex: 12.50" oninput="updNet()"><p class="mn">Vous recevrez : <strong id="smNet" style="color:var(--vc-green)">0.00€</strong></p><div class="mr"><button class="rb" onclick="cMod('sellM')">Annuler</button><button class="rb pri" onclick="confirmSell()">Mettre en vente</button></div></div></div>
<!-- Ship Modal -->
<div class="mbg" id="shipM"><div class="mod"><button class="mx" onclick="cMod('shipM')">×</button><h2>📦 Demander l'envoi</h2><p class="mn">Frais d'envoi : <strong style="color:var(--vc-gold)">4.99€</strong></p><input class="mi" placeholder="Nom complet"><input class="mi" placeholder="Adresse"><input class="mi" placeholder="Code postal"><input class="mi" placeholder="Ville"><div id="shipInfo" class="mn"></div><div class="mr"><button class="rb" onclick="cMod('shipM')">Annuler</button><button class="rb pri" onclick="confirmShip()">Confirmer (4.99€)</button></div></div></div>
<!-- Recycle Modal -->
<div class="mbg" id="recM"><div class="mod"><button class="mx" onclick="cMod('recM')">×</button><h2>♻️ Recycler les cartes</h2><p class="mn">Recyclage instantané — <strong style="color:var(--vc-cyan)">40%</strong> de la valeur.</p><div id="recInfo"></div><div class="mr"><button class="rb" onclick="cMod('recM')">Annuler</button><button class="rb pri" onclick="confirmRec()">♻️ Recycler</button></div></div></div>
<!-- Negotiate Modal -->
<div class="mbg" id="negoM"><div class="mod"><button class="mx" onclick="cMod('negoM')">×</button><h2>💬 Négocier le prix</h2><p class="mn">Le vendeur sera notifié par email et sur le site.</p><div style="display:flex;align-items:center;gap:.5rem;margin:.5rem 0"><span id="ngE" style="font-size:1.5rem"></span><div><div id="ngN" style="font-weight:700"></div><div id="ngP" style="font-family:'JetBrains Mono';color:var(--vc-text-secondary);font-size:.85rem"></div></div></div><label style="font-size:.75rem;color:var(--vc-text-secondary)">Votre offre (€)</label><input class="mi" id="ngOffer" type="number" step="0.01" min="0.01" placeholder="Votre proposition"><div class="mr"><button class="rb" onclick="cMod('negoM')">Annuler</button><button class="rb pri" onclick="sendNego()">Envoyer l'offre</button></div></div></div>
<!-- Confirm Buy Modal -->
<div class="mbg" id="confirmBuyM"><div class="mod"><button class="mx" onclick="cMod('confirmBuyM')">×</button><h2>🛒 Confirmer l'achat</h2><div id="cbInfo"></div><div class="mr"><button class="rb" onclick="cMod('confirmBuyM')">Annuler</button><button class="rb pri" id="cbBtn">Confirmer</button></div></div></div>
<!-- Sell All Modal -->
<div class="mbg" id="sellAllM"><div class="mod"><button class="mx" onclick="cMod('sellAllM')">×</button><h2>💱 Vendre tous les exemplaires</h2><p class="mn">Chaque exemplaire sera mis en vente au même prix. Commission de 8%.</p><div id="saInfo"></div><label style="font-size:.75rem;color:var(--vc-text-secondary)">Prix par carte (€)</label><input class="mi" id="saP" type="number" step="0.01" min="0.01" placeholder="Ex: 5.00" oninput="updSaNet()"><p class="mn">Vous recevrez : <strong id="saNet" style="color:var(--vc-green)">0.00€</strong></p><div class="mr"><button class="rb" onclick="cMod('sellAllM')">Annuler</button><button class="rb pri" onclick="confirmSellAll()">Tout mettre en vente</button></div></div></div>
<!-- Recycle All Modal -->
<div class="mbg" id="recAllM"><div class="mod"><button class="mx" onclick="cMod('recAllM')">×</button><h2>♻️ Recycler tous les exemplaires</h2><p class="mn">Recyclage instantané — <strong style="color:var(--vc-cyan)">40%</strong> de la valeur.</p><div id="raInfo"></div><div class="mr"><button class="rb" onclick="cMod('recAllM')">Annuler</button><button class="rb pri" onclick="confirmRecAll()">♻️ Tout recycler</button></div></div></div>
<!-- Ship Cart Modal -->
<div class="mbg" id="shipCartM"><div class="mod" style="max-width:440px"><button class="mx" onclick="cMod('shipCartM')">×</button><h2>📦 Panier d'envoi</h2><p class="mn">Sélectionnez les cartes à envoyer. Frais uniques : <strong style="color:var(--vc-gold)">4.99€</strong></p><div id="scList" style="max-height:300px;overflow-y:auto;margin:.5rem 0"></div><div id="scSummary" style="font-size:.8rem;color:var(--vc-text-secondary);padding:.5rem 0;border-top:1px solid var(--vc-border)"></div><div class="mr"><button class="rb" onclick="cMod('shipCartM')">Fermer</button><button class="rb" style="border-color:rgba(239,68,68,.3);color:#ef4444" onclick="shipCart=[];renderShipBadge();cMod('shipCartM');toast('Panier vidé','ok')">🗑️ Vider</button><button class="rb pri" onclick="confirmShipCart()">📦 Confirmer l'envoi (4.99€)</button></div></div></div>
<div class="toast" id="toast"><span id="tI"></span><span id="tT"></span></div>
<!-- AUTH MODAL -->
<div class="mbg" id="authM"><div class="mod" style="max-width:380px">
  <button class="mx" onclick="cMod('authM')">×</button>
  <div style="text-align:center;margin-bottom:.8rem"><div style="font-size:1.8rem;margin-bottom:.3rem">🃏</div><div style="font-family:'Exo 2';font-weight:800;font-size:1.1rem;background:linear-gradient(135deg,var(--vc-primary-light),var(--vc-accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent">VAULTA CLUB</div></div>
  <div style="display:flex;gap:0;margin-bottom:1rem;border-bottom:1px solid var(--vc-border)"><button class="auth-tab on" id="tabLogin" onclick="authTab('login')" style="flex:1;background:0;border:0;color:var(--vc-primary-light);font-family:'Chakra Petch';font-weight:600;padding:.7rem;cursor:pointer;border-bottom:2px solid var(--vc-primary)">Connexion</button><button class="auth-tab" id="tabReg" onclick="authTab('register')" style="flex:1;background:0;border:0;color:var(--vc-text-dim);font-family:'Chakra Petch';font-weight:600;padding:.7rem;cursor:pointer;border-bottom:2px solid transparent">Inscription</button></div>
  <div id="authErr" style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#fca5a5;font-size:.75rem;padding:.5rem .7rem;border-radius:var(--r-sm);margin-bottom:.5rem;display:none"></div>
  <div class="auth-form on" id="fLogin">
    <input class="mi" id="lEmail" type="email" placeholder="Email" autocomplete="email">
    <input class="mi" id="lPass" type="password" placeholder="Mot de passe" autocomplete="current-password">
    <button style="width:100%;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border:0;font-family:'Chakra Petch';font-weight:700;font-size:.9rem;padding:.7rem;border-radius:var(--r-sm);cursor:pointer" id="btnLogin" onclick="doLogin()">Se connecter</button>
    <p class="mn" style="text-align:center;cursor:pointer;color:var(--vc-primary-light);margin-top:.6rem" onclick="authTab('register')">Pas encore de compte ? <strong>Créer un compte</strong></p>
  </div>
  <div class="auth-form" id="fRegister">
    <input class="mi" id="rUser" type="text" placeholder="Pseudo (3-20 caractères)" autocomplete="username">
    <input class="mi" id="rEmail" type="email" placeholder="Email" autocomplete="email">
    <input class="mi" id="rPass" type="password" placeholder="Mot de passe (min 6 car.)" autocomplete="new-password">
    <input class="mi" id="rPass2" type="password" placeholder="Confirmer le mot de passe" autocomplete="new-password">
    <button style="width:100%;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border:0;font-family:'Chakra Petch';font-weight:700;font-size:.9rem;padding:.7rem;border-radius:var(--r-sm);cursor:pointer" id="btnReg" onclick="doRegister()">Créer mon compte</button>
    <p class="mn" style="text-align:center;cursor:pointer;color:var(--vc-primary-light);margin-top:.6rem" onclick="authTab('login')">Déjà un compte ? <strong>Se connecter</strong></p>
  </div>
</div></div>

