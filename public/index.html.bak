function nowStr(){return new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})+' '+new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'})}
function dateShort(){return new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})}

