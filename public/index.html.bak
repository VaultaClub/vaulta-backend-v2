  {id:5,fr:'pokemon',name:'Forces Temporelles',sub:'Écarlate & Violet',series:'Écarlate & Violet',price:5.50,cards:10,badge:'ltd',badgeText:'LIMITÉ',stock:6,grad:'linear-gradient(135deg,#ea580c,#f59e0b,#eab308)',emoji:'⏰',boosterImg:'https://images.pokemontcg.io/sv5/logo.png',
  pool:[{name:'Walking Wake ex',r:'secret',e:'🌊',v:42,img:'https://images.pokemontcg.io/sv5/24.png'},{name:'Iron Leaves ex',r:'ultra',e:'🍃',v:15,img:'https://images.pokemontcg.io/sv5/23.png'},{name:'Flygon ex',r:'rare',e:'🐉',v:6,img:'https://images.pokemontcg.io/sv5/91.png'},{name:'Raikou',r:'rare',e:'⚡',v:5,img:'https://images.pokemontcg.io/sv5/33.png'},{name:'Ralts',r:'common',e:'💚',v:0.3,img:'https://images.pokemontcg.io/sv5/60.png'},{name:'Teddiursa',r:'common',e:'🧸',v:0.2,img:'https://images.pokemontcg.io/sv5/127.png'},{name:'Magikarp',r:'common',e:'🐟',v:0.1,img:'https://images.pokemontcg.io/sv5/29.png'}]},
  {id:6,fr:'pokemon',name:'Masque Crépusculaire',sub:'Écarlate & Violet',series:'Écarlate & Violet',price:5.50,cards:10,badge:'new',badgeText:'NOUVEAU',stock:30,grad:'linear-gradient(135deg,#14532d,#166534,#15803d)',emoji:'🎭',boosterImg:'https://images.pokemontcg.io/sv6/logo.png',
  pool:[{name:'Terapagos ex',r:'secret',e:'✨',v:48,img:'https://images.pokemontcg.io/sv6/171.png'},{name:'Sinistcha ex',r:'rare',e:'🍵',v:6,img:'https://images.pokemontcg.io/sv6/28.png'},{name:'Dipplin',r:'uncommon',e:'🍎',v:2,img:'https://images.pokemontcg.io/sv6/14.png'},{name:'Poltchageist',r:'common',e:'🫖',v:0.5,img:'https://images.pokemontcg.io/sv6/26.png'},{name:'Applin',r:'common',e:'🍏',v:0.3,img:'https://images.pokemontcg.io/sv6/12.png'},{name:'Phantump',r:'common',e:'🌳',v:0.2,img:'https://images.pokemontcg.io/sv6/24.png'},{name:'Lombre',r:'uncommon',e:'🌿',v:1,img:'https://images.pokemontcg.io/sv6/5.png'}]}
];
const qty={};P.forEach(p=>qty[p.id]=1);

/* ============ NAV ============ */
function go(pg){
  if(['coll','mkt','wal','prof'].includes(pg) && !currentUser){openAuth();return}
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));document.getElementById('p-'+pg).classList.add('on');document.querySelectorAll('.nb,.mb').forEach(b=>b.classList.toggle('on',b.dataset.p===pg));if(pg==='coll')renderColl();if(pg==='mkt')renderMkt();if(pg==='wal')renderTx();if(pg==='prof')renderProfile()}

/* ============ SHOP ============ */
function renderShop(f='all'){
  const g=document.getElementById('shopG'),list=f==='all'?P:P.filter(p=>p.fr===f);
  g.innerHTML=list.map(p=>{
    const sc=p.stock>10?'':p.stock>3?'low':'out',sl=p.stock>0?`${p.stock} dispo`:'Épuisé';
    return `<div class="prd" ${p.stock>0?`onclick="buyPack(${p.id})"`:'style="opacity:.5;cursor:default"'}>
      <div class="prd-img" style="background:${p.grad.replace('135deg','180deg')};background-blend-mode:overlay;background-color:rgba(8,8,14,.7)">
        ${p.badge?`<div class="prd-bdg ${p.badge}">${p.badgeText}</div>`:''}
        <div class="prd-stk"><div class="sd ${sc}"></div>${sl}</div>
        <div class="bv" style="background:${p.grad}"><img src="${p.boosterImg}" style="width:85%;height:auto;object-fit:contain;filter:drop-shadow(0 4px 10px rgba(0,0,0,.5))" onerror="this.outerHTML='${p.emoji}'"></div>
      </div>
      <div class="prd-nfo"><div class="prd-fr">${p.fr.toUpperCase()}</div><div class="prd-nm">${p.sub} — ${p.name}</div><div class="prd-mt">${p.cards} cartes par booster</div>
        <div class="prd-ft"><div class="prd-pr">${p.price.toFixed(2)}€</div>
          <div style="display:flex;align-items:center;gap:.4rem">
            <div style="display:flex;align-items:center;gap:.2rem" onclick="event.stopPropagation()">
              <button class="qb" onclick="event.stopPropagation();chgQ(${p.id},-1)">−</button>
              <span class="qv" id="q-${p.id}">${qty[p.id]}</span>
              <button class="qb" onclick="event.stopPropagation();chgQ(${p.id},1)">+</button>
            </div>
            <button class="ob" onclick="event.stopPropagation();buyPack(${p.id})">OUVRIR</button>
          </div></div></div></div>`}).join('');
}
function filt(f,el){document.querySelectorAll('.flt .ch').forEach(c=>c.classList.remove('on'));el.classList.add('on');renderShop(f)}
function chgQ(id,d){qty[id]=Math.max(1,Math.min(10,(qty[id]||1)+d));const e=document.getElementById('q-'+id);if(e)e.textContent=qty[id]}

/* ============ BUY & OPEN ============ */
let boosterQueue=[];
function buyPack(id){
  if(!currentUser){openAuth();return}
  const p=P.find(x=>x.id===id);if(!p||p.stock<=0)return;
  const n=qty[id]||1,tot=p.price*n;
  if(bal<tot){toast('Solde insuffisant !','err');return}
  bal-=tot;p.stock-=n;updBal();addTxH('pur',`${n}x ${p.name}`,-tot);
  qty[id]=1; // Reset qty after purchase
  const openTime=nowStr();
  // Build a queue of boosters to open one at a time
  boosterQueue=[];
  for(let b=0;b<n;b++){
    const bRef=genRef();
    const cards=[];
    for(let j=0;j<p.cards;j++){
      const c=rndC(p.pool);
      cards.push({...c,pName:p.name,fr:p.fr,series:p.series||p.sub,prodId:p.id,boosterRef:bRef,openDate:openTime,videoUrl:'#video-'+bRef});
    }
    cards.sort((a,b)=>{const o={common:0,uncommon:1,rare:2,ultra:3,secret:4};return o[a.r]-o[b.r]});
    boosterQueue.push({prod:p,cards,bRef,num:b+1,total:n});
  }
  openNextBooster();
}
function rndC(pool){const w={common:50,uncommon:25,rare:15,ultra:7,secret:3};const wt=pool.flatMap(c=>Array(w[c.r]||10).fill(c));return wt[Math.floor(Math.random()*wt.length)]}

/* ============ OVERLAY ============ */
function showOv(p){
  const ov=document.getElementById('overlay'),tp=document.getElementById('tearP'),ts=document.getElementById('tearS'),tg=document.getElementById('tearG');
  tp.className='tear-p';ts.style.display='';document.getElementById('stackS').classList.remove('on');document.getElementById('revC').classList.remove('on');document.getElementById('tearT').style.display='block';
  tg.style.background=`radial-gradient(circle,${(p.grad.match(/#[a-f0-9]{6}/gi)||['#6366f1'])[0]}55,transparent 70%)`;
  ['tiL','tiR'].forEach(id=>{const el=document.getElementById(id);el.style.background=p.grad;el.innerHTML=`<span style="font-size:3.5rem">${p.emoji}</span>`});
  ov.classList.add('open');
}
function tear(){
  const tp=document.getElementById('tearP');if(tp.classList.contains('torn')||tp.classList.contains('tearing'))return;
  tp.classList.add('tearing');tp.style.animation='none';document.getElementById('tearT').style.display='none';
  setTimeout(()=>{tp.classList.remove('tearing');tp.classList.add('torn');burst(innerWidth/2,innerHeight/2,30)},600);
  setTimeout(()=>{document.getElementById('tearS').style.display='none';buildStack()},1200);
}
function buildStack(){
  const ss=document.getElementById('stackS'),sc=document.getElementById('stackC'),rc=document.getElementById('revC'),ctr=document.getElementById('sCtr'),strip=document.getElementById('rStrip');
  strip.innerHTML='';strip.classList.remove('on');pileCnt=0;isRev=false;revIdx=0;
  document.getElementById('rPile').querySelectorAll('.pc').forEach(c=>c.remove());document.getElementById('pCnt').textContent='';
  if(autoT){clearInterval(autoT);autoT=null}
  document.getElementById('bNext').style.display='';document.getElementById('bAuto').style.display='';document.getElementById('bSkip').style.display='none';document.getElementById('bStore').style.display='none';
  const rC={common:'var(--vc-text-dim)',uncommon:'var(--vc-green)',rare:'var(--vc-blue)',ultra:'var(--vc-gold)',secret:'var(--vc-accent)'};
  const rl={common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'};
  const tot=revCards.length;
  const remaining=tot-0;
  // Build pile backs (visual stack of remaining cards)
  sc.innerHTML=`<div class="sc-pile-backs" id="pileBacks">
    ${Array.from({length:Math.min(3,tot)},()=>`<div class="sc-pile-back"><div class="sc-bd"><div class="sc-bl">VAULTA</div><div class="sc-bs">CLUB</div></div></div>`).join('')}
  </div>
  <div class="sc-active" id="activeCard" onclick="revNext()"></div>`;
  ctr.textContent=`0 / ${tot}`;ctr.style.display='block';ss.classList.add('on');rc.classList.add('on');
}
let revIdx=0;
function revNext(){
  if(isRev)return;isRev=true;
  const tot=revCards.length;
  // Add PREVIOUS card to pile (if any)
  if(revIdx>0){
    addPile(revCards[revIdx-1]);addStrip(revCards[revIdx-1]);
  }
  if(revIdx>=tot){isRev=false;allDone();return}
  const c=revCards[revIdx];
  const rC={common:'var(--vc-text-dim)',uncommon:'var(--vc-green)',rare:'var(--vc-blue)',ultra:'var(--vc-gold)',secret:'var(--vc-accent)'};
  const rl={common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'};
  const ac=document.getElementById('activeCard');
  ac.className='sc-active ry-'+c.r;
  ac.innerHTML=`${c.img?`<img class="sc-card-img" src="${c.img}" onerror="this.style.display='none'">`:`<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:4rem;background:var(--vc-bg-surface);border-radius:var(--r-lg)">${c.e}</div>`}
    <div class="sc-front-info">
      <div class="sc-front-name">${c.name}</div>
      <div class="sc-front-rar" style="color:${rC[c.r]}">${rl[c.r]}</div>
      <div class="sc-front-val">${c.v.toFixed(2)}€</div>
    </div>`;
  ac.classList.remove('on');void ac.offsetWidth;ac.classList.add('on');
  // Update pile backs (remaining after this one)
  const remaining=tot-revIdx-1;
  const pb=document.getElementById('pileBacks');
  if(remaining<=0)pb.style.display='none';
  else{
    pb.style.display='';
    pb.innerHTML=Array.from({length:Math.min(3,remaining)},()=>`<div class="sc-pile-back"><div class="sc-bd"><div class="sc-bl">VAULTA</div><div class="sc-bs">CLUB</div></div></div>`).join('');
  }
  if(['rare','ultra','secret'].includes(c.r))setTimeout(()=>{const r=ac.getBoundingClientRect();burst(r.left+r.width/2,r.top+r.height/2,25,c.r)},300);
  revIdx++;
  document.getElementById('sCtr').textContent=`${revIdx} / ${tot}`;
  // If this was the last card, show done after a pause
  if(revIdx>=tot){
    setTimeout(()=>{isRev=false;allDone()},1200);
  }else{
    setTimeout(()=>{isRev=false},400);
  }
}
function addPile(c){const pile=document.getElementById('rPile'),off=pileCnt*1.2,rot=(Math.random()-.5)*8,el=document.createElement('div');el.className='pc';el.style.transform=`translateY(${-off}px) rotate(${rot}deg)`;el.style.zIndex=pileCnt;if(c.img)el.innerHTML=`<img src="${c.img}" onerror="this.parentElement.style.background='var(--vc-bg-surface)'">`; else{el.style.background='var(--vc-bg-surface)';el.style.display='flex';el.style.alignItems='center';el.style.justifyContent='center';el.style.border='1px solid var(--vc-border)';el.innerHTML=`<span style="font-size:1.8rem">${c.e}</span>`}pile.insertBefore(el,pile.querySelector('.pcnt'));pileCnt++;document.getElementById('pCnt').textContent=`${pileCnt} carte${pileCnt>1?'s':''}`}
function addStrip(c){const s=document.getElementById('rStrip');s.classList.add('on');const el=document.createElement('div');el.className=`stc s-${c.r}`;el.innerHTML=`${c.img?`<img src="${c.img}" onerror="this.remove()">`:''}
  <div class="stc-lb"><div class="stc-n">${c.name}</div><div class="stc-v">${c.v.toFixed(2)}€</div></div>`;s.appendChild(el);s.scrollLeft=s.scrollWidth}
function startAuto(){if(autoT)return;document.getElementById('bNext').style.display='none';document.getElementById('bAuto').style.display='none';document.getElementById('bSkip').style.display='';revNext();autoT=setInterval(()=>{if(revIdx>=revCards.length){clearInterval(autoT);autoT=null;return}revNext()},1800)}
function skipEnd(){if(autoT){clearInterval(autoT);autoT=null}isRev=false;
  // Add all remaining cards to pile (including current if shown)
  const startFrom=Math.max(0,revIdx>0?revIdx-1:0);
  for(let i=startFrom;i<revCards.length;i++){
    addPile(revCards[i]);addStrip(revCards[i]);
  }
  revIdx=revCards.length;
  document.getElementById('activeCard').classList.remove('on');
  document.getElementById('pileBacks').style.display='none';
  document.getElementById('sCtr').textContent=`${revCards.length} / ${revCards.length} ✓`;
  // Show store button
  document.getElementById('bNext').style.display='none';
  document.getElementById('bAuto').style.display='none';
  document.getElementById('bSkip').style.display='none';
  document.getElementById('bStore').style.display='';
  document.getElementById('stackS').classList.remove('on');
  const btn=document.getElementById('bStore');
  if(boosterQueue.length>0){
    btn.innerHTML=`✅ Stocker & Ouvrir le suivant (${boosterQueue.length} restant${boosterQueue.length>1?'s':''})`;
  }else{
    btn.innerHTML='✅ Stocker dans ma collection';
  }
}
function allDone(){
  if(autoT){clearInterval(autoT);autoT=null}
  // Add last card to pile
  if(revCards.length>0){
    const last=revCards[revCards.length-1];
    addPile(last);addStrip(last);
  }
  document.getElementById('activeCard').classList.remove('on');
  document.getElementById('bNext').style.display='none';
  document.getElementById('bAuto').style.display='none';
  document.getElementById('bSkip').style.display='none';
  document.getElementById('bStore').style.display='';
  document.getElementById('stackS').classList.remove('on');
  document.getElementById('sCtr').textContent=`${revCards.length} / ${revCards.length} ✓`;
  // Update button text based on remaining boosters
  const btn=document.getElementById('bStore');
  if(boosterQueue.length>0){
    btn.innerHTML=`✅ Stocker & Ouvrir le suivant (${boosterQueue.length} restant${boosterQueue.length>1?'s':''})`;
  }else{
    btn.innerHTML='✅ Stocker dans ma collection';
  }
}
function storeAll(){
  if(!revCards.length){closeOv();return}
  revCards.forEach(c=>coll.push({...c,id:Date.now()+Math.random(),stored:true}));
  toast(`${revCards.length} cartes ajoutées !`,'ok');
  saveLocal();
  if(boosterQueue.length>0){
    // Stay in overlay, reset for next booster
    resetForNextBooster();
    openNextBooster();
  }else{
    closeOv();renderShop();
  }
}
function resetForNextBooster(){
  // Reset card reveal state without closing overlay
  if(autoT){clearInterval(autoT);autoT=null}
  isRev=false;pileCnt=0;revIdx=0;
  document.getElementById('stackS').classList.remove('on');
  document.getElementById('sCtr').style.display='none';
  document.getElementById('revC').classList.remove('on');
  document.getElementById('rStrip').classList.remove('on');
  document.getElementById('rStrip').innerHTML='';
  document.getElementById('rPile').querySelectorAll('.pc').forEach(c=>c.remove());
  document.getElementById('pCnt').textContent='';
  curProd=null;revCards=[];
}
function openNextBooster(){
  if(!boosterQueue.length){closeOv();renderShop();saveLocal();return}
  const b=boosterQueue.shift();
  curProd=b.prod;revCards=b.cards;
  // Show booster badge
  const badge=document.getElementById('boosterBadge');
  if(b.total>1){
    badge.textContent=`📦 Booster ${b.num}/${b.total}`;
    badge.style.display='';
  }else{
    badge.style.display='none';
  }
  // Show booster tear animation (overlay already open)
  const tp=document.getElementById('tearP'),ts=document.getElementById('tearS'),tg=document.getElementById('tearG');
  tp.className='tear-p';ts.style.display='';document.getElementById('tearT').style.display='block';
  tg.style.background=`radial-gradient(circle,${(b.prod.grad.match(/#[a-f0-9]{6}/gi)||['#6366f1'])[0]}55,transparent 70%)`;
  ['tiL','tiR'].forEach(id=>{const el=document.getElementById(id);el.style.background=b.prod.grad;el.innerHTML=`<span style="font-size:3.5rem">${b.prod.emoji}</span>`});
  // If overlay not open yet, open it
  document.getElementById('overlay').classList.add('open');
}
function closeOv(){if(autoT){clearInterval(autoT);autoT=null}isRev=false;pileCnt=0;revIdx=0;document.getElementById('overlay').classList.remove('open');document.getElementById('stackS').classList.remove('on');document.getElementById('sCtr').style.display='none';document.getElementById('revC').classList.remove('on');document.getElementById('rStrip').classList.remove('on');document.getElementById('rStrip').innerHTML='';document.getElementById('rPile').querySelectorAll('.pc').forEach(c=>c.remove());document.getElementById('pCnt').textContent='';document.getElementById('boosterBadge').style.display='none';curProd=null;revCards=[]}
function burst(cx,cy,cnt=20,rar='rare'){const b=document.getElementById('ptclB'),cols={rare:['#3b82f6','#60a5fa','#93c5fd'],ultra:['#f59e0b','#fbbf24','#fde68a'],secret:['#a78bfa','#c084fc','#e879f9']}[rar]||['#3b82f6','#60a5fa'];for(let i=0;i<cnt;i++){const p=document.createElement('div');p.className='ptcl';p.style.left=cx+'px';p.style.top=cy+'px';p.style.background=cols[Math.floor(Math.random()*cols.length)];p.style.setProperty('--px',(Math.random()-.5)*250+'px');p.style.setProperty('--py',(Math.random()-.5)*250+'px');const s=3+Math.random()*7;p.style.width=s+'px';p.style.height=s+'px';b.appendChild(p);setTimeout(()=>p.remove(),1200)}}

/* ============ COLLECTION ============ */
function setCV(v){collV=v;document.getElementById('vGrid').classList.toggle('on',v==='grid');document.getElementById('vBind').classList.toggle('on',v==='binder');renderColl()}
function renderColl(){
  document.getElementById('cTot').textContent=coll.length;document.getElementById('cVal').textContent=coll.reduce((s,c)=>s+c.v,0).toFixed(2)+'€';
  if(collV==='grid'){document.getElementById('collB').classList.remove('on');renderCollGrid()}else{document.getElementById('collG').innerHTML='';renderBinder()}
}
function renderCollGrid(){
  const el=document.getElementById('collG');
  if(!coll.length){el.innerHTML='<div class="empty"><div class="ei">📦</div><div class="et">Collection vide</div><div class="es">Ouvrez des boosters dans la boutique !</div></div>';return}
  const groups={};coll.forEach(c=>{const k=c.fr+'|'+c.pName;if(!groups[k])groups[k]={fr:c.fr,name:c.pName,cards:[]};groups[k].cards.push(c)});
  el.innerHTML=Object.values(groups).map(g=>{
    const uniq=new Set(g.cards.map(c=>c.name)).size,prod=P.find(p=>p.name===g.name),pool=prod?prod.pool.length:uniq,pct=Math.round(uniq/pool*100);
    const byName={};g.cards.forEach(c=>{if(!byName[c.name])byName[c.name]={cards:[],count:0};byName[c.name].cards.push(c);byName[c.name].count++});
    return `<div class="set-blk"><div class="set-bar"><div class="set-tt">${g.fr.toUpperCase()} — ${g.name}</div><div class="set-pr"><div class="pb"><div class="pbf" style="width:${pct}%"></div></div><span class="pbt">${uniq}/${pool} (${pct}%)</span></div></div>
      <div class="cgrd">${Object.values(byName).map(({cards,count})=>{const c=cards[0],ids=cards.map(x=>x.id);return `
        <div class="cc" onclick="showCDGroup(${JSON.stringify(ids).replace(/"/g,'&quot;')},0)">
          <div class="rd rd-${c.r}"></div>
          ${count>1?`<div class="copies-badge">×${count}</div>`:''}
          ${c.img?`<img src="${c.img}" onerror="this.remove()">`:''}
          <div class="cc-lb"><div class="cc-nm">${c.name}</div><div class="cc-vl">${c.v.toFixed(2)}€</div></div>
        </div>`}).join('')}</div></div>`}).join('');
}

/* ============ CARD DETAIL (with navigation) ============ */
function showCDGroup(ids,idx){cdCards=ids;cdIdx=idx;cdCtx='coll';renderCD()}
function showCDSingle(cardId){cdCards=[cardId];cdIdx=0;cdCtx='coll';renderCD()}
function renderCD(){
  const cardId=cdCards[cdIdx],c=coll.find(x=>String(x.id)===String(cardId));if(!c)return;
  const rl={common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'};
  const rCol={common:'#888',uncommon:'var(--vc-green)',rare:'var(--vc-blue)',ultra:'var(--vc-gold)',secret:'var(--vc-accent)'};
  let imgHTML=c.img?`<img src="${c.img}">`:`<div style="width:260px;height:364px;background:var(--vc-bg-surface);display:flex;align-items:center;justify-content:center;font-size:4rem;border-radius:var(--r-lg)">${c.e}</div>`;
  let navHTML='';
  if(cdCards.length>1){
    navHTML=`<div class="cdm-nav"><button class="cdm-nav-btn" onclick="cdNav(-1)" ${cdIdx<=0?'disabled':''}>◀ Préc.</button><button class="cdm-nav-btn" onclick="cdNav(1)" ${cdIdx>=cdCards.length-1?'disabled':''}>Suiv. ▶</button></div><div class="cdm-nav-lbl">Exemplaire ${cdIdx+1} / ${cdCards.length}</div>`;
  }
  document.getElementById('cdImg').innerHTML=imgHTML+navHTML;
  document.getElementById('cdName').textContent=c.name;
  document.getElementById('cdRar').innerHTML=`<span style="color:${rCol[c.r]}">${rl[c.r]}</span>`;
  document.getElementById('cdVal').textContent=c.v.toFixed(2)+'€';
  document.getElementById('cdMeta').innerHTML=`
    <div class="cdm-row">📦 Booster : <span>${c.pName}</span></div>
    <div class="cdm-row">🏷️ Réf booster : <span>${c.boosterRef||'N/A'}</span></div>
    <div class="cdm-row">📅 Ouvert le : <span>${c.openDate||'N/A'}</span></div>
    <div class="cdm-row" style="cursor:pointer;color:var(--vc-primary-light)" onclick="toast('🎬 Vidéo de ${c.boosterRef||'ce booster'} bientôt disponible !','ok')">▶️ Voir la vidéo d'ouverture (${c.boosterRef||'N/A'})</div>`;
  // Check if in ship cart
  const inCart=shipCart.some(x=>String(x)===String(c.id));
  const allRec=cdCards.reduce((s,id)=>{const card=coll.find(x=>String(x.id)===String(id));return s+(card?card.v*0.4:0)},0);
  const multi=cdCards.length>1;
  let acts=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:.35rem;margin-top:.3rem">
    <button class="cdm-act sell" onclick="closeCD();openSellM('${c.id}')"><span class="cdm-act-i">💱</span>Vendre</button>
    ${multi?`<button class="cdm-act sell-m" onclick="closeCD();openSellAllM(${JSON.stringify(cdCards).replace(/"/g,'&quot;')})"><span class="cdm-act-i">💱</span>Vendre les ${cdCards.length} unités</button>`:'<div></div>'}
    <button class="cdm-act rec" onclick="closeCD();recycleSingle('${c.id}')"><span class="cdm-act-i">♻️</span>Recycler (${(c.v*.4).toFixed(2)}€)</button>
    ${multi?`<button class="cdm-act rec-m" onclick="closeCD();recycleAllM(${JSON.stringify(cdCards).replace(/"/g,'&quot;')})"><span class="cdm-act-i">♻️</span>Recycler les ${cdCards.length} unités (${allRec.toFixed(2)}€)</button>`:'<div></div>'}
    <button class="cdm-act ship${inCart?' on':''}" onclick="toggleShipCart('${c.id}')"><span class="cdm-act-i">${inCart?'✓':'📦'}</span>${inCart?'Retirer du panier':'Recevoir'}</button>
    ${multi?`<button class="cdm-act ship-m" onclick="addAllToShipCart(${JSON.stringify(cdCards).replace(/"/g,'&quot;')})"><span class="cdm-act-i">📦</span>Recevoir les ${cdCards.length} unités</button>`:'<div></div>'}
  </div><div style="text-align:center;margin-top:.4rem"><button class="cdm-close" onclick="closeCD()">Fermer</button></div>`;
  document.getElementById('cdActs').innerHTML=acts;
  document.getElementById('cardDetail').classList.add('on');
}
function cdNav(d){cdIdx=Math.max(0,Math.min(cdCards.length-1,cdIdx+d));renderCD()}
function closeCD(){document.getElementById('cardDetail').classList.remove('on')}

/* ============ BINDER ============ */
function renderBinder(){
  const binder=document.getElementById('collB');
  if(!coll.length){binder.innerHTML='<div class="empty"><div class="ei">📖</div><div class="et">Classeur vide</div></div>';binder.classList.add('on');return}
  const grps={};coll.forEach(c=>{if(!grps[c.pName])grps[c.pName]={name:c.pName,fr:c.fr,cards:[]};grps[c.pName].cards.push(c)});
  window._bd={grps,gNames:Object.keys(grps),gi:0,pg:0};renderBP();binder.classList.add('on');
}
function renderBP(){
  const binder=document.getElementById('collB'),bd=window._bd;if(!bd)return;
  const gn=bd.gNames[bd.gi],grp=bd.grps[gn],prod=P.find(p=>p.name===grp.name),pool=prod?prod.pool:[],spp=9,pg=bd.pg;
  const owned={};grp.cards.forEach(c=>{if(!owned[c.name])owned[c.name]={cards:[],count:0};owned[c.name].cards.push(c);owned[c.name].count++});
  const ownedCount=Object.keys(owned).length,totalPool=pool.length,pct=totalPool?Math.round(ownedCount/totalPool*100):0;
  const ls=pg*spp*2,rs=ls+spp,mx=Math.max(1,Math.ceil(pool.length/(spp*2)));
  const mkS=(st)=>{let h='';for(let i=st;i<st+spp;i++){const card=pool[i];if(!card){h+=`<div class="bsl empty"><span class="bsn">${i+1}</span><div class="bse">—</div></div>`}
    else{const o=owned[card.name];if(o&&card.img){const ids=o.cards.map(x=>x.id);h+=`<div class="bsl filled" onclick="showCDGroup(${JSON.stringify(ids).replace(/"/g,'&quot;')},0)"><span class="bsn">#${i+1}</span><img src="${card.img}" onerror="this.remove()">${o.count>1?`<div class="copies-badge">×${o.count}</div>`:''}</div>`}
    else if(o){const ids=o.cards.map(x=>x.id);h+=`<div class="bsl filled" onclick="showCDGroup(${JSON.stringify(ids).replace(/"/g,'&quot;')},0)"><span class="bsn">#${i+1}</span><div class="bse">${card.e}</div><div class="bsnm">${card.name}</div>${o.count>1?`<div class="copies-badge">×${o.count}</div>`:''}</div>`}
    else{h+=`<div class="bsl empty"><span class="bsn">#${i+1}</span><div class="bse">${card.e}</div><div class="bsnm">${card.name}</div></div>`}}}return h};
  binder.innerHTML=`<div class="bb"><div class="bn">
    <div><select onchange="swBG(this.value)" style="background:var(--vc-bg-surface);border:1px solid var(--vc-border);color:var(--vc-text);padding:.25rem .4rem;border-radius:5px;font-family:'Chakra Petch';font-size:.8rem">${bd.gNames.map((n,i)=>`<option value="${i}" ${i===bd.gi?'selected':''}>${bd.grps[n].fr.toUpperCase()} — ${n}</option>`).join('')}</select></div>
    <div class="bn-stats"><span>${ownedCount}/${totalPool} cartes</span><span class="bn-pct">(${pct}%)</span></div>
    <div style="display:flex;align-items:center;gap:.5rem"><span style="font-family:'JetBrains Mono';font-size:.7rem;color:var(--vc-text-secondary)">Page ${pg+1}/${mx}</span><div class="ba"><button class="bar" onclick="bPrev()">◀</button><button class="bar" onclick="bNext()">▶</button></div></div>
  </div><div class="bp"><div class="bpg"><div class="bpgrd">${mkS(ls)}</div></div><div class="bsp"></div><div class="bpg"><div class="bpgrd">${mkS(rs)}</div></div></div></div>`;
}
function swBG(i){window._bd.gi=+i;window._bd.pg=0;renderBP()}
function bPrev(){if(window._bd.pg>0){window._bd.pg--;renderBP()}}
function bNext(){const bd=window._bd,gn=bd.gNames[bd.gi],prod=P.find(p=>p.name===bd.grps[gn].name),pool=prod?prod.pool:[],mx=Math.max(1,Math.ceil(pool.length/18));if(bd.pg<mx-1){bd.pg++;renderBP()}}

/* ============ CARD ACTIONS ============ */
let shipCart=[];
function openSellM(cardId){const c=coll.find(x=>String(x.id)===String(cardId));if(!c)return;pendSell=c;document.getElementById('smE').textContent=c.e;document.getElementById('smN').textContent=c.name;document.getElementById('smR').textContent={common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'}[c.r];document.getElementById('smP').value=c.v.toFixed(2);updNet();document.getElementById('sellM').classList.add('on')}
function updNet(){const p=parseFloat(document.getElementById('smP').value)||0;document.getElementById('smNet').textContent=(p*.92).toFixed(2)+'€'}
function confirmSell(){if(!pendSell)return;const pr=parseFloat(document.getElementById('smP').value);if(!pr||pr<=0){toast('Prix invalide','err');return}
  const c=pendSell;coll=coll.filter(x=>String(x.id)!==String(c.id));window._mktL=window._mktL||[];
  window._mktL.push({name:c.name,e:c.e,price:pr,seller:'Vous',r:c.r,set:c.pName,img:c.img,boosterRef:c.boosterRef,openDate:c.openDate,videoUrl:c.videoUrl,series:c.series||'',featured:false,listDate:nowStr()});
  toast(`${c.name} en vente pour ${pr.toFixed(2)}€ !`,'ok');pendSell=null;cMod('sellM');renderColl();saveLocal()}

// Sell ALL copies
function openSellAllM(ids){
  const cards=ids.map(id=>coll.find(x=>String(x.id)===String(id))).filter(Boolean);
  if(!cards.length)return;
  const c=cards[0],n=cards.length;
  pendSellAll=cards;
  document.getElementById('saInfo').innerHTML=`<div style="display:flex;align-items:center;gap:.7rem;margin:.6rem 0"><span style="font-size:1.8rem">${c.e}</span><div><div style="font-weight:700">${c.name} × ${n}</div><div style="font-size:.7rem;color:var(--vc-text-dim)">${{common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'}[c.r]}</div></div></div>`;
  document.getElementById('saP').value=c.v.toFixed(2);updSaNet();
  document.getElementById('sellAllM').classList.add('on');
}
function updSaNet(){const p=parseFloat(document.getElementById('saP').value)||0;const n=pendSellAll?pendSellAll.length:1;document.getElementById('saNet').textContent=(p*.92*n).toFixed(2)+'€ ('+n+' cartes)'}
function confirmSellAll(){
  if(!pendSellAll||!pendSellAll.length)return;
  const pr=parseFloat(document.getElementById('saP').value);if(!pr||pr<=0){toast('Prix invalide','err');return}
  window._mktL=window._mktL||[];
  pendSellAll.forEach(c=>{
    coll=coll.filter(x=>String(x.id)!==String(c.id));
    window._mktL.push({name:c.name,e:c.e,price:pr,seller:'Vous',r:c.r,set:c.pName,img:c.img,boosterRef:c.boosterRef,openDate:c.openDate,videoUrl:c.videoUrl,series:c.series||'',featured:false,listDate:nowStr()});
  });
  toast(`${pendSellAll.length}× ${pendSellAll[0].name} en vente !`,'ok');
  pendSellAll=null;cMod('sellAllM');renderColl();saveLocal();
}
let pendSellAll=null;

// Recycle ALL copies
function recycleAllM(ids){
  const cards=ids.map(id=>coll.find(x=>String(x.id)===String(id))).filter(Boolean);
  if(!cards.length)return;
  pendRecAll=cards;
  const tot=cards.reduce((s,c)=>s+c.v,0),cr=+(tot*.4).toFixed(2);
  document.getElementById('raInfo').innerHTML=`<div style="margin:.5rem 0;padding:.8rem;background:var(--vc-bg-surface);border-radius:7px"><div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem"><span style="font-size:1.5rem">${cards[0].e}</span><strong>${cards[0].name} × ${cards.length}</strong></div>Valeur totale : ${tot.toFixed(2)}€<br><span style="font-size:1.1rem;color:var(--vc-cyan);font-family:'JetBrains Mono';font-weight:700">→ +${cr.toFixed(2)}€</span></div>`;
  document.getElementById('recAllM').classList.add('on');
}
function confirmRecAll(){
  if(!pendRecAll||!pendRecAll.length)return;
  const tot=pendRecAll.reduce((s,c)=>s+c.v,0),cr=+(tot*.4).toFixed(2);
  bal+=cr;pendRecAll.forEach(c=>{coll=coll.filter(x=>String(x.id)!==String(c.id))});
  updBal();addTxH('rec',`♻️ ${pendRecAll.length}× ${pendRecAll[0].name}`,cr);
  toast(`${pendRecAll.length} cartes recyclées → +${cr.toFixed(2)}€`,'ok');
  pendRecAll=null;cMod('recAllM');renderColl();saveLocal();
}
let pendRecAll=null;

function recycleSingle(cardId){
  const c=coll.find(x=>String(x.id)===String(cardId));if(!c)return;
  const cr=+(c.v*.4).toFixed(2);
  pendRec=[c];
  document.getElementById('recInfo').innerHTML=`<div style="margin:.5rem 0;padding:.8rem;background:var(--vc-bg-surface);border-radius:7px;display:flex;align-items:center;gap:.7rem">
    <div style="width:50px;height:70px;border-radius:6px;overflow:hidden;flex-shrink:0;background:var(--vc-bg-elevated);display:flex;align-items:center;justify-content:center">${c.img?`<img src="${c.img}" style="width:100%;height:100%;object-fit:cover">`:`<span style="font-size:1.5rem">${c.e}</span>`}</div>
    <div><div style="font-weight:700">${c.name}</div><div style="font-size:.7rem;color:var(--vc-text-dim)">${{common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'}[c.r]}</div>
    <div style="margin-top:.3rem">Valeur : ${c.v.toFixed(2)}€ → <span style="color:var(--vc-cyan);font-family:'JetBrains Mono';font-weight:700">+${cr.toFixed(2)}€</span></div></div></div>`;
  document.getElementById('recM').classList.add('on');
}

// Ship cart
function toggleShipCart(cardId){
  const idx=shipCart.findIndex(x=>String(x)===String(cardId));
  if(idx>=0){shipCart.splice(idx,1);toast('Retiré du panier','ok')}
  else{shipCart.push(cardId);toast('Ajouté au panier 📦','ok')}
  renderCD();renderShipBadge();
}
function addAllToShipCart(ids){
  ids.forEach(id=>{if(!shipCart.some(x=>String(x)===String(id)))shipCart.push(id)});
  toast(`${ids.length} cartes ajoutées au panier 📦`,'ok');
  renderCD();renderShipBadge();
}
function renderShipBadge(){
  let badge=document.getElementById('shipCartBadge');
  if(!badge){
    badge=document.createElement('div');badge.id='shipCartBadge';
    badge.style.cssText='position:fixed;bottom:20px;right:20px;z-index:150;background:linear-gradient(135deg,var(--vc-primary),var(--vc-secondary));color:#fff;border-radius:16px;padding:.6rem 1rem;cursor:pointer;font-family:Chakra Petch;font-weight:700;font-size:.85rem;box-shadow:0 8px 30px rgba(99,102,241,.4);display:flex;align-items:center;gap:.5rem;transition:.3s';
    badge.onclick=()=>openShipCartM();
    document.body.appendChild(badge);
  }
  const btn=document.getElementById('shipCartBtn');
  if(shipCart.length>0){
    badge.style.display='flex';
    badge.innerHTML=`📦 Panier d'envoi <span style="background:rgba(255,255,255,.25);padding:.15rem .45rem;border-radius:10px;font-family:JetBrains Mono;font-size:.75rem">${shipCart.length}</span>`;
    if(btn){btn.style.display='';btn.textContent='📦 Panier ('+shipCart.length+')';}
  }else{
    badge.style.display='none';
    if(btn)btn.style.display='none';
  }
}
function openShipCartM(){
  const cards=shipCart.map(id=>coll.find(x=>String(x.id)===String(id))).filter(Boolean);
  // Clean up any removed cards
  shipCart=cards.map(c=>c.id);
  if(!cards.length){toast('Panier vide !','err');renderShipBadge();return}
  document.getElementById('scList').innerHTML=cards.map(c=>`<div style="display:flex;align-items:center;gap:.6rem;padding:.5rem 0;border-bottom:1px solid var(--vc-border)">
    <div style="width:40px;height:56px;border-radius:5px;overflow:hidden;flex-shrink:0;background:var(--vc-bg-surface);display:flex;align-items:center;justify-content:center">${c.img?`<img src="${c.img}" style="width:100%;height:100%;object-fit:cover">`:`<span style="font-size:1.2rem">${c.e}</span>`}</div>
    <div style="flex:1;min-width:0"><div style="font-weight:600;font-size:.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.name}</div><div style="font-size:.65rem;color:var(--vc-text-dim)">${c.pName} — ${c.v.toFixed(2)}€</div></div>
    <button style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#ef4444;font-size:.7rem;padding:.25rem .5rem;border-radius:5px;cursor:pointer;font-family:Chakra Petch" onclick="removeFromCart('${c.id}')">✕</button>
  </div>`).join('');
  const totalVal=cards.reduce((s,c)=>s+c.v,0);
  document.getElementById('scSummary').innerHTML=`${cards.length} carte${cards.length>1?'s':''} — Valeur : ${totalVal.toFixed(2)}€ — <strong style="color:var(--vc-gold)">Envoi : 4.99€</strong>`;
  document.getElementById('shipCartM').classList.add('on');
}
function removeFromCart(cardId){
  shipCart=shipCart.filter(x=>String(x)!==String(cardId));
  renderShipBadge();
  if(shipCart.length>0)openShipCartM(); else cMod('shipCartM');
}
function confirmShipCart(){
  if(bal<4.99){toast('Solde insuffisant (4.99€)','err');return}
  const cards=shipCart.map(id=>coll.find(x=>String(x.id)===String(id))).filter(Boolean);
  if(!cards.length){toast('Panier vide','err');return}
  bal-=4.99;
  coll=coll.filter(c=>!shipCart.some(x=>String(x)===String(c.id)));
  updBal();addTxH('pur',`📦 Envoi ${cards.length} carte${cards.length>1?'s':''}`,-4.99);
  toast(`${cards.length} carte(s) en route 🚀`,'ok');
  shipCart=[];renderShipBadge();cMod('shipCartM');renderColl();saveLocal();
}
function shipSingle(cardId){shipCart=[cardId];renderShipBadge();openShipCartM()}
function bulkRecycle(){if(!coll.length){toast('Collection vide !','err');return}pendRec=[...coll];const tot=coll.reduce((s,c)=>s+c.v,0),cr=+(tot*.4).toFixed(2);document.getElementById('recInfo').innerHTML=`<div style="margin:.8rem 0;padding:.8rem;background:var(--vc-bg-surface);border-radius:7px"><strong>${coll.length}</strong> cartes — Valeur : ${tot.toFixed(2)}€<br><span style="font-size:1rem;color:var(--vc-cyan);font-family:'JetBrains Mono';font-weight:700">→ +${cr.toFixed(2)}€</span></div>`;document.getElementById('recM').classList.add('on')}
function confirmRec(){if(!pendRec.length)return;const tot=pendRec.reduce((s,c)=>s+c.v,0),cr=+(tot*.4).toFixed(2);bal+=cr;coll=coll.filter(c=>!pendRec.find(r=>r.id===c.id));updBal();addTxH('rec',`♻️ ${pendRec.length} cartes`,cr);toast(`${pendRec.length} cartes recyclées → +${cr.toFixed(2)}€`,'ok');pendRec=[];cMod('recM');renderColl();saveLocal()}
function bulkShip(){if(!coll.length){toast('Collection vide !','err');return}shipCart=coll.map(c=>c.id);renderShipBadge();openShipCartM()}
function confirmShip(){if(bal<4.99){toast('Solde insuffisant','err');return}bal-=4.99;const n=pendShip.length;coll=coll.filter(c=>!pendShip.includes(c.id)&&!pendShip.includes(String(c.id)));updBal();addTxH('pur','📦 Envoi',-4.99);cMod('shipM');toast(`${n} carte(s) en route 🚀`,'ok');pendShip=[];renderColl();saveLocal()}

/* ============ MARKETPLACE ============ */
const sampleMkt=[
  {name:'Charizard ex',e:'🔥',price:42,seller:'DragonMaster',r:'secret',set:'Flammes Obsidiennes',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv3/183.png',featured:true,fr:'pokemon',boosterRef:'VLT-X7K2-4201',openDate:'23 Fév 2026 14:32',videoUrl:'#',listDate:'24 Fév 2026 10:15'},
  {name:'Mew ex',e:'🧬',price:50,seller:'PsyTrainer',r:'secret',set:'151',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv3pt5/205.png',featured:true,fr:'pokemon',boosterRef:'VLT-M3W1-3892',openDate:'22 Fév 2026 18:05',videoUrl:'#',listDate:'23 Fév 2026 09:30'},
  {name:'Dragonite ex',e:'🐉',price:13.50,seller:'DragonFan',r:'ultra',set:'Flammes Obsidiennes',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv3/159.png',featured:false,fr:'pokemon',boosterRef:'VLT-DR4G-7721',openDate:'21 Fév 2026 20:14',videoUrl:'#',listDate:'22 Fév 2026 11:45'},
  {name:'Iron Valiant ex',e:'⚔️',price:35,seller:'FutureTech',r:'secret',set:'Faille Paradoxe',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv4/205.png',featured:true,fr:'pokemon',boosterRef:'VLT-IR0N-5503',openDate:'20 Fév 2026 16:22',videoUrl:'#',listDate:'21 Fév 2026 08:00'},
  {name:'Chien-Pao ex',e:'❄️',price:38,seller:'IceKing',r:'secret',set:'Évolutions à Paldea',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv2/176.png',featured:false,fr:'pokemon',boosterRef:'VLT-IC3K-2918',openDate:'19 Fév 2026 12:00',videoUrl:'#',listDate:'20 Fév 2026 14:20'},
  {name:'Pikachu',e:'⚡',price:0.80,seller:'StarterPack',r:'common',set:'151',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv3pt5/25.png',featured:false,fr:'pokemon',boosterRef:'VLT-PKA1-6644',openDate:'18 Fév 2026 09:30',videoUrl:'#',listDate:'19 Fév 2026 10:00'},
  {name:'Zapdos ex',e:'⚡',price:11,seller:'ThunderBird',r:'ultra',set:'151',series:'Écarlate & Violet',img:'https://images.pokemontcg.io/sv3pt5/145.png',featured:false,fr:'pokemon',boosterRef:'VLT-ZAP3-1192',openDate:'17 Fév 2026 15:45',videoUrl:'#',listDate:'18 Fév 2026 16:30'}
];

let mktFiltTCG='all',mktFiltSeries='all',mktFiltRar='all',mktSort='default';
function renderMkt(){
  const fl=document.getElementById('mktFilters');
  const tcgs=[...new Set(['pokemon',...(window._mktL||[]).map(l=>l.fr||'pokemon')])];
  const allItems=[...sampleMkt,...(window._mktL||[])];
  const seriesForTCG=mktFiltTCG==='all'?[...new Set(allItems.map(i=>i.series).filter(Boolean))]:[...new Set(allItems.filter(i=>(i.fr||'pokemon')===mktFiltTCG).map(i=>i.series).filter(Boolean))];
  const rars=['all','common','uncommon','rare','ultra','secret'];
  const rarLbl={all:'Toutes',common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'};
  fl.innerHTML=`
    <label>TCG</label><select onchange="mktFiltTCG=this.value;mktFiltSeries='all';renderMkt()"><option value="all">Tous</option>${tcgs.map(t=>`<option value="${t}" ${mktFiltTCG===t?'selected':''}>${t.charAt(0).toUpperCase()+t.slice(1)}</option>`).join('')}</select>
    <label>Série</label><select onchange="mktFiltSeries=this.value;renderMkt()"><option value="all">Toutes</option>${seriesForTCG.map(s=>`<option value="${s}" ${mktFiltSeries===s?'selected':''}>${s}</option>`).join('')}</select>
    <label>Rareté</label><select onchange="mktFiltRar=this.value;renderMkt()">${rars.map(r=>`<option value="${r}" ${mktFiltRar===r?'selected':''}>${rarLbl[r]}</option>`).join('')}</select>
    <label>Prix</label><select onchange="mktSort=this.value;renderMkt()"><option value="default" ${mktSort==='default'?'selected':''}>Défaut</option><option value="asc" ${mktSort==='asc'?'selected':''}>Croissant</option><option value="desc" ${mktSort==='desc'?'selected':''}>Décroissant</option></select>`;
  let items=[...sampleMkt,...(window._mktL||[])];
  if(mktFiltTCG!=='all')items=items.filter(i=>(i.fr||'pokemon')===mktFiltTCG);
  if(mktFiltSeries!=='all')items=items.filter(i=>i.series===mktFiltSeries);
  if(mktFiltRar!=='all')items=items.filter(i=>i.r===mktFiltRar);
  if(mktSort==='asc')items.sort((a,b)=>getEffPrice(a)-getEffPrice(b));
  else if(mktSort==='desc')items.sort((a,b)=>getEffPrice(b)-getEffPrice(a));
  const feat=items.filter(i=>i.featured),reg=items.filter(i=>!i.featured);
  document.getElementById('mktFeat').innerHTML=feat.length?`<div class="mkt-featured-title">⭐ Mises en avant</div><div class="mkgrd">${feat.map(i=>mkCard(i,true)).join('')}</div>`:'';
  document.getElementById('mktG').innerHTML=reg.length?reg.map(i=>mkCard(i,false)).join(''):(feat.length?'':'<div class="empty"><div class="ei">🔍</div><div class="et">Aucune carte trouvée</div></div>');
}
function getEffPrice(item){const k=negoKey(item);const h=negoHistory[k];if(h&&h.accepted)return h.acceptedPrice;return item.price}
function negoKey(item){return (item.name+'|'+item.seller+'|'+item.boosterRef).replace(/\s/g,'')}
function mkCard(item,feat){
  const k=negoKey(item),h=negoHistory[k],eff=getEffPrice(item);
  let priceHTML=`<span class="mk-pr">${eff.toFixed(2)}€</span>`;
  if(h&&h.accepted)priceHTML=`<span class="mk-pr-old">${item.price.toFixed(2)}€</span><span class="mk-pr">${h.acceptedPrice.toFixed(2)}€</span>`;
  let negoHTML='';
  if(h&&h.refusals&&h.refusals.length)negoHTML=`<div class="mk-nego-hist">❌ ${h.refusals.length} offre(s) refusée(s)</div>`;
  const safe=JSON.stringify(item).replace(/'/g,"\\'").replace(/"/g,'&quot;');
  return `<div class="mk ${feat?'featured':''}" onclick='showMktDetail(${safe})'>
    <div class="mk-top"><span class="mk-slr">@${item.seller}</span><span class="mk-date">${item.listDate||''}</span></div>
    <div class="mk-vis">${item.img?`<img src="${item.img}">`:`<div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:2rem">${item.e}</div>`}</div>
    <div class="mk-nm">${item.name}</div><div class="mk-set">${item.set}</div>
    <div class="mk-ref">Réf: ${item.boosterRef||'N/A'} — Tiré le ${item.openDate||'N/A'}</div>
    <div class="mk-ft">${priceHTML}<button class="mk-buy" onclick="event.stopPropagation();confirmBuyMkt(${safe})">Acheter</button></div>
    ${negoHTML}</div>`}

function showMktDetail(item){
  const rl={common:'Commune',uncommon:'Peu commune',rare:'Rare',ultra:'Ultra Rare',secret:'Secrète'};
  const rCol={common:'#888',uncommon:'var(--vc-green)',rare:'var(--vc-blue)',ultra:'var(--vc-gold)',secret:'var(--vc-accent)'};
  const k=negoKey(item),h=negoHistory[k],eff=getEffPrice(item);
  document.getElementById('cdImg').innerHTML=item.img?`<img src="${item.img}">`:`<div style="width:260px;height:364px;background:var(--vc-bg-surface);display:flex;align-items:center;justify-content:center;font-size:4rem;border-radius:var(--r-lg)">${item.e}</div>`;
  document.getElementById('cdName').textContent=item.name;
  document.getElementById('cdRar').innerHTML=`<span style="color:${rCol[item.r]}">${rl[item.r]}</span>`;
  document.getElementById('cdVal').textContent=eff.toFixed(2)+'€'+(h&&h.accepted?` (ancien: ${item.price.toFixed(2)}€)`:'');
  let metaHTML=`
    <div class="cdm-row">📦 Set : <span>${item.set}</span></div>
    <div class="cdm-row">🏷️ Réf booster : <span>${item.boosterRef||'N/A'}</span></div>
    <div class="cdm-row">📅 Tiré le : <span>${item.openDate||'N/A'}</span></div>
    <div class="cdm-row">👤 Vendeur : <span>@${item.seller}</span></div>
    <div class="cdm-row">🗓️ Mis en vente : <span>${item.listDate||'N/A'}</span></div>
    <div class="cdm-row" style="cursor:pointer;color:var(--vc-primary-light)" onclick="toast('🎬 Vidéo du booster ${item.boosterRef||''} bientôt disponible !','ok')">▶️ Voir la vidéo d'ouverture</div>`;
  if(h&&h.refusals&&h.refusals.length){metaHTML+=`<div class="cdm-row" style="color:var(--vc-fire)">❌ Offres refusées : ${h.refusals.map(r=>r.toFixed(2)+'€').join(', ')}</div>`}
  if(h&&h.accepted){metaHTML+=`<div class="cdm-row" style="color:var(--vc-green)">✅ Prix négocié accepté : ${h.acceptedPrice.toFixed(2)}€</div>`}
  document.getElementById('cdMeta').innerHTML=metaHTML;
  const safeItem=JSON.stringify(item).replace(/'/g,"\\'").replace(/"/g,'&quot;');
  document.getElementById('cdActs').innerHTML=`
    <button class="cdm-btn" style="border-color:rgba(52,211,153,.3)" onclick="closeCD();confirmBuyMkt(${safeItem})">🛒 Acheter (${eff.toFixed(2)}€)</button>
    <button class="cdm-btn" style="border-color:rgba(99,102,241,.3)" onclick="closeCD();openNego('${item.name.replace(/'/g,"\\'")}','${item.e}',${item.price},'${item.seller}','${(item.boosterRef||'').replace(/'/g,"\\'")}')">💬 Négocier le prix</button>
    <button class="cdm-btn" onclick="closeCD()">✕ Fermer</button>`;
  document.getElementById('cardDetail').classList.add('on');
}

/* Confirm buy on marketplace */
function confirmBuyMkt(item){
  const eff=getEffPrice(item);
  document.getElementById('cbInfo').innerHTML=`<div style="display:flex;align-items:center;gap:.7rem;margin:.8rem 0"><span style="font-size:2rem">${item.e}</span><div><div style="font-weight:700">${item.name}</div><div style="font-size:.78rem;color:var(--vc-text-secondary)">${item.set} — @${item.seller}</div><div style="font-family:'JetBrains Mono';color:var(--vc-gold);font-weight:700;margin-top:.2rem">${eff.toFixed(2)}€</div></div></div>`;
  document.getElementById('cbBtn').onclick=()=>{
    if(bal<eff){toast('Solde insuffisant !','err');return}
    bal-=eff;updBal();coll.push({id:Date.now()+Math.random(),name:item.name,e:item.e,r:item.r,v:eff,img:item.img||'',pName:item.set,fr:item.fr||'pokemon',series:item.series||'',boosterRef:item.boosterRef||'',openDate:item.openDate||'',videoUrl:item.videoUrl||'#',stored:true});
    addTxH('pur',`Marché: ${item.name}`,-eff);toast(`${item.name} acheté !`,'ok');cMod('confirmBuyM');
  };
  document.getElementById('confirmBuyM').classList.add('on');
}
function openNego(name,e,price,seller,ref){
  window._curMktItem=window._curMktItem||{name,e,price,seller,boosterRef:ref};
  document.getElementById('ngE').textContent=e;document.getElementById('ngN').textContent=name;
  document.getElementById('ngP').textContent=`Prix actuel : ${price.toFixed(2)}€ — @${seller}`;
  document.getElementById('ngOffer').value='';document.getElementById('negoM').classList.add('on');
}
function sendNego(){const item=window._curMktItem;if(!item)return;const v=parseFloat(document.getElementById('ngOffer').value);if(!v||v<=0){toast('Montant invalide','err');return}
  const k=negoKey(item);if(!negoHistory[k])negoHistory[k]={refusals:[],accepted:false,acceptedPrice:0};
  if(Math.random()<0.3){negoHistory[k].accepted=true;negoHistory[k].acceptedPrice=v;cMod('negoM');toast(`🎉 Offre de ${v.toFixed(2)}€ acceptée par @${item.seller} !`,'ok');renderMkt()}
  else{negoHistory[k].refusals.push(v);cMod('negoM');toast(`❌ Offre de ${v.toFixed(2)}€ refusée par @${item.seller}`,'err');renderMkt()}
}
function buyMkt(name,price,emoji,rar,img){if(bal<price){toast('Solde insuffisant !','err');return}bal-=price;updBal();coll.push({id:Date.now()+Math.random(),name,e:emoji,r:rar,v:price,img:img||'',pName:'Marché',fr:'market',stored:true});addTxH('pur',`Marché: ${name}`,-price);toast(`${name} acheté !`,'ok')}

// ========== WALLET ==========
let depCustom=false;
function selD(amt,el){document.querySelectorAll('.dc').forEach(c=>c.classList.remove('sel'));el.classList.add('sel');
  if(amt===-1){depCustom=true;document.getElementById('customDep').classList.add('on');document.getElementById('depBtn').textContent='Déposer';depAmt=0}
  else{depCustom=false;depAmt=amt;document.getElementById('customDep').classList.remove('on');document.getElementById('depBtn').textContent=`Déposer ${amt}€`}}
function deposit(){
  if(!currentUser){openAuth();return}
  let amt=depAmt;if(depCustom){amt=parseFloat(document.getElementById('customAmt').value);if(!amt||amt<1){toast('Montant min 1€','err');return}}
  bal+=amt;updBal();addTxH('dep','Dépôt',amt);toast(`+${amt.toFixed(2)}€ !`,'ok');
}
function updBal(){document.getElementById('hBal').textContent=bal.toFixed(2)+'€';document.getElementById('wBal').textContent=bal.toFixed(2)}
function addTxH(type,desc,amt){txHistory.unshift({type,desc,amt,date:new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'short',year:'numeric'})});txPage=0;renderTx();saveLocal()}
function renderTx(){
  const list=document.getElementById('txList'),nav=document.getElementById('txNav');
  const start=txPage*TX_PP,end=start+TX_PP,page=txHistory.slice(start,end),totalPages=Math.ceil(txHistory.length/TX_PP);
  const icons={dep:'💰',pur:'🛒',sale:'💱',rec:'♻️'};
  list.innerHTML=page.map(t=>`<div class="txi"><div class="txl"><div class="txic ${t.type}">${icons[t.type]||'📝'}</div><div><div class="txd">${t.desc}</div><div class="txdt">${t.date}</div></div></div><div class="txa ${t.amt>0?'pos':'neg'}">${t.amt>0?'+':''}${t.amt.toFixed(2)}€</div></div>`).join('');
  nav.innerHTML=totalPages>1?`<button class="tx-nav-btn" onclick="txPg(-1)" ${txPage<=0?'disabled':''}>◀</button><span class="tx-nav-pg">${txPage+1} / ${totalPages}</span><button class="tx-nav-btn" onclick="txPg(1)" ${txPage>=totalPages-1?'disabled':''}>▶</button>`:'';
}
function txPg(d){const mx=Math.ceil(txHistory.length/TX_PP)-1;txPage=Math.max(0,Math.min(mx,txPage+d));renderTx()}

// ========== MODALS / TOAST ==========
function cMod(id){document.getElementById(id).classList.remove('on')}
function toast(msg,type='ok'){const t=document.getElementById('toast');document.getElementById('tI').textContent=type==='ok'?'✅':'❌';document.getElementById('tT').textContent=msg;t.className='toast '+type+' on';setTimeout(()=>t.classList.remove('on'),3500)}

// ========== AUTH STATE ==========
let currentUser=null;
let authToken=localStorage.getItem('vc_token')||null;

// ========== AUTH ==========
function authTab(tab){
  document.querySelectorAll('.auth-tab').forEach(t=>{t.classList.remove('on');t.style.color='var(--vc-text-dim)';t.style.borderBottomColor='transparent'});
  document.querySelectorAll('.auth-form').forEach(f=>f.classList.remove('on'));
  const activeTab=document.getElementById('tab'+(tab==='login'?'Login':'Reg'));
  activeTab.classList.add('on');activeTab.style.color='var(--vc-primary-light)';activeTab.style.borderBottomColor='var(--vc-primary)';
  document.getElementById('f'+(tab==='login'?'Login':'Register')).classList.add('on');
  document.getElementById('authErr').style.display='none';
}
function showAuthErr(msg){const e=document.getElementById('authErr');e.textContent=msg;e.style.display='block'}
function openAuth(){document.getElementById('authM').classList.add('on');authTab('login')}

const API=async(path,opts={})=>{
  const headers={'Content-Type':'application/json'};
  if(authToken)headers['Authorization']='Bearer '+authToken;
  const res=await fetch('/api'+path,{...opts,headers});
  const data=await res.json();
  if(!res.ok)throw new Error(data.error||'Erreur serveur');
  return data;
};

async function doLogin(){
  const email=document.getElementById('lEmail').value.trim();
  const password=document.getElementById('lPass').value;
  if(!email||!password){showAuthErr('Remplissez tous les champs');return}
  const btn=document.getElementById('btnLogin');btn.disabled=true;btn.textContent='Connexion...';
  try{
    const data=await API('/auth/login',{method:'POST',body:JSON.stringify({email,password})});
    authToken=data.token;localStorage.setItem('vc_token',authToken);
    currentUser=data.user;onLoginSuccess();cMod('authM');toast('Bienvenue '+currentUser.username+' !','ok');
  }catch(err){showAuthErr(err.message)}
  finally{btn.disabled=false;btn.textContent='Se connecter'}
}
async function doRegister(){
  const username=document.getElementById('rUser').value.trim();
  const email=document.getElementById('rEmail').value.trim();
  const password=document.getElementById('rPass').value;
  const password2=document.getElementById('rPass2').value;
  if(!username||!email||!password){showAuthErr('Remplissez tous les champs');return}
  if(password!==password2){showAuthErr('Les mots de passe ne correspondent pas');return}
  if(password.length<6){showAuthErr('Mot de passe min 6 caractères');return}
  const btn=document.getElementById('btnReg');btn.disabled=true;btn.textContent='Création...';
  try{
    const data=await API('/auth/register',{method:'POST',body:JSON.stringify({username,email,password})});
    authToken=data.token;localStorage.setItem('vc_token',authToken);
    currentUser=data.user;onLoginSuccess();cMod('authM');toast('Compte créé ! Bienvenue '+currentUser.username+' 🎉','ok');
  }catch(err){showAuthErr(err.message)}
  finally{btn.disabled=false;btn.textContent='Créer mon compte'}
}
async function doLogout(){
  try{await API('/auth/logout',{method:'POST'})}catch(e){}
  authToken=null;currentUser=null;localStorage.removeItem('vc_token');
  coll=[];txHistory=[];bal=0;negoHistory={};
  updateAuthUI();go('shop');toast('Déconnecté','ok');closeUM();
}
function toggleUserMenu(){
  if(!currentUser){openAuth();return}
  const m=document.getElementById('userMenu');
  const isOpen=m.style.display==='block';
  m.style.display=isOpen?'none':'block';
  if(!isOpen){
    const close=e=>{if(!document.getElementById('avBtn').contains(e.target)){m.style.display='none';document.removeEventListener('click',close)}};
    setTimeout(()=>document.addEventListener('click',close),10);
  }
}
function closeUM(){document.getElementById('userMenu').style.display='none'}
function updateAuthUI(){
  const pill=document.getElementById('hBalPill');
  const avText=document.getElementById('avText');
  if(currentUser){
    pill.style.display='';bal=currentUser.balance||bal;updBal();
    const initials=currentUser.username.substring(0,2).toUpperCase();
    avText.textContent=currentUser.avatar||initials;
    document.getElementById('umName').textContent=currentUser.username;
    document.getElementById('umEmail').textContent=currentUser.email;
    document.getElementById('umLvl').textContent='Niveau '+(currentUser.level||1)+' — '+(currentUser.xp||0)+' XP';
  }else{
    pill.style.display='none';avText.textContent='?';
  }
}
function renderProfile(){
  if(!currentUser)return;
  const av=document.getElementById('profAv');
  if(currentUser.avatar)av.textContent=currentUser.avatar;
  else av.textContent=currentUser.username.substring(0,2).toUpperCase();
  document.getElementById('profName').textContent=currentUser.username;
  document.getElementById('profEmail').textContent=currentUser.email;
  document.getElementById('profEditName').value=currentUser.username;
  document.getElementById('profEditEmail').textContent=currentUser.email;
  document.getElementById('profLvlBadge').textContent='Niv. '+(currentUser.level||1);
  document.getElementById('profXP').textContent=(currentUser.xp||0)+' XP';
  document.getElementById('profCards').textContent=coll.length;
  document.getElementById('profValue').textContent=coll.reduce((s,c)=>s+c.v,0).toFixed(2)+'€';
  const uniqueRefs=new Set(coll.map(c=>c.boosterRef).filter(Boolean));
  document.getElementById('profBoosters').textContent=uniqueRefs.size;
  document.getElementById('profJoined').textContent=currentUser.joinedAt||new Date().toLocaleDateString('fr-FR');
  // Avatar picker
  const avatars=['🐉','⚡','🔥','❄️','🧬','🦊','🐲','💎','🎭','⭐','🌙','🎴','🃏','👑','🦋','🌺'];
  document.getElementById('avatarGrid').innerHTML=avatars.map(a=>`<div class="prof-avatar-opt ${currentUser.avatar===a?'sel':''}" onclick="setAvatar('${a}')">${a}</div>`).join('');
  // Recent history
  const recent=txHistory.slice(0,5);
  const icons={dep:'💰',pur:'🛒',sale:'💱',rec:'♻️'};
  document.getElementById('profHistory').innerHTML=recent.length?recent.map(t=>`<div class="prof-row"><label>${icons[t.type]||'📝'} ${t.desc}</label><span class="${t.amt>0?'':''}style="color:${t.amt>0?'var(--vc-green)':'var(--vc-fire)'}; font-family:JetBrains Mono;font-size:.8rem">${t.amt>0?'+':''}${t.amt.toFixed(2)}€</span></div>`).join(''):'<p style="font-size:.8rem;color:var(--vc-text-dim);padding:.5rem 0">Aucune transaction</p>';
}
function setAvatar(emoji){
  currentUser.avatar=emoji;
  localStorage.setItem('vc_avatar',emoji);
  updateAuthUI();renderProfile();
  document.getElementById('avatarPicker').style.display='none';
  toast('Avatar mis à jour !','ok');
}
function saveProfile(){
  const name=document.getElementById('profEditName').value.trim();
  if(name.length<3){toast('Pseudo min 3 caractères','err');return}
  currentUser.username=name;
  updateAuthUI();renderProfile();
  toast('Profil sauvegardé !','ok');
}
function onLoginSuccess(){
  const savedAvatar=localStorage.getItem('vc_avatar');
  if(savedAvatar)currentUser.avatar=savedAvatar;
  loadLocal();
  updateAuthUI();renderColl();renderTx();
}
async function checkAuth(){
  if(!authToken)return;
  try{
    const data=await API('/auth/me');
    currentUser={id:data.id,username:data.username,email:data.email,role:data.role,balance:data.balance,xp:data.xp,level:data.level};
    onLoginSuccess();
  }catch(e){authToken=null;localStorage.removeItem('vc_token')}
}

// ========== LOCAL PERSISTENCE ==========
function saveLocal(){
  if(!currentUser)return;
  const key='vc_data_'+currentUser.id;
  try{
    localStorage.setItem(key,JSON.stringify({bal,coll,txHistory,negoHistory}));
  }catch(e){console.warn('Save failed',e)}
}
function loadLocal(){
  if(!currentUser)return;
  const key='vc_data_'+currentUser.id;
  try{
    const raw=localStorage.getItem(key);
    if(raw){
      const d=JSON.parse(raw);
      if(d.bal!==undefined)bal=d.bal;
      if(d.coll)coll=d.coll;
      if(d.txHistory)txHistory=d.txHistory;
      if(d.negoHistory)negoHistory=d.negoHistory;
    }else{
      // First login — welcome bonus
      bal=currentUser.balance||45;
      txHistory=[{type:'dep',desc:'🎁 Bonus de bienvenue',amt:bal,date:dateShort()}];
    }
    updBal();
  }catch(e){console.warn('Load failed',e)}
}

// ========== INIT ==========
renderShop();renderTx();checkAuth();
document.addEventListener('scroll',()=>{const m=document.getElementById('userMenu');if(m)m.style.display='none'});
document.getElementById('lPass')?.addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});
document.getElementById('rPass2')?.addEventListener('keydown',e=>{if(e.key==='Enter')doRegister()});
</script>
</body>
</html>
