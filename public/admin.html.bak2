<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vaulta Club — Administration</title>
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Exo+2:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#06060c;--bg-card:#0c0c18;--bg-s:#111124;--bg-e:#1a1a32;--bg-h:#222244;--pri:#6366f1;--pri-l:#818cf8;--sec:#7c3aed;--acc:#a78bfa;--gold:#fbbf24;--fire:#ef4444;--green:#34d399;--cyan:#22d3ee;--amber:#f59e0b;--text:#e8e8f0;--text2:#9898b8;--dim:#5a5a78;--border:#1e1e3a;--r:10px}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Chakra Petch',sans-serif;display:flex;min-height:100vh}
::selection{background:var(--pri);color:#fff}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
/* Sidebar */
.side{width:240px;background:var(--bg-card);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:50;transition:transform .3s}
.s-logo{padding:1.2rem 1rem;display:flex;align-items:center;gap:.6rem;border-bottom:1px solid var(--border)}
.s-logo-i{width:34px;height:34px;background:linear-gradient(135deg,var(--pri),var(--sec));border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Exo 2';font-weight:900;font-size:.9rem;color:#fff}
.s-logo-t{font-family:'Exo 2';font-weight:900;font-size:1rem;letter-spacing:2px;background:linear-gradient(135deg,var(--pri-l),var(--acc));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.s-logo-sub{font-size:.5rem;color:var(--amber);letter-spacing:3px;text-transform:uppercase;font-weight:700}
.s-nav{flex:1;padding:.8rem .5rem;overflow-y:auto;display:flex;flex-direction:column;gap:.15rem}
.s-sec{font-size:.55rem;color:var(--dim);text-transform:uppercase;letter-spacing:2.5px;padding:.8rem .7rem .3rem;font-weight:700}
.s-btn{display:flex;align-items:center;gap:.6rem;padding:.55rem .7rem;border-radius:8px;cursor:pointer;transition:.2s;font-size:.82rem;font-weight:500;color:var(--text2);border:none;background:none;width:100%;text-align:left}
.s-btn:hover{background:var(--bg-s);color:var(--text)}.s-btn.on{background:rgba(99,102,241,.1);color:var(--pri-l);font-weight:600}
.s-btn .ico{font-size:1rem;width:22px;text-align:center;flex-shrink:0}
.s-btn .badge{margin-left:auto;background:var(--fire);color:#fff;font-family:'JetBrains Mono';font-size:.55rem;font-weight:700;padding:.1rem .4rem;border-radius:50px;min-width:18px;text-align:center}
.s-foot{padding:1rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:.5rem}
.s-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--amber),var(--fire));display:flex;align-items:center;justify-content:center;font-family:'Exo 2';font-weight:800;font-size:.7rem;color:#fff}
.s-uname{font-size:.78rem;font-weight:600}.s-urole{font-size:.55rem;color:var(--amber)}
/* Main */
.content{margin-left:240px;flex:1;min-height:100vh}
.topbar{height:56px;background:rgba(6,6,12,.8);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1.5rem;gap:1rem;position:sticky;top:0;z-index:40}
.tb-title{font-family:'Exo 2';font-weight:800;font-size:1.1rem;flex:1}
.tb-search{background:var(--bg-s);border:1px solid var(--border);border-radius:8px;padding:.35rem .8rem;color:var(--text);font-family:'Chakra Petch';font-size:.82rem;width:280px;outline:none;transition:border .2s}
.tb-search:focus{border-color:var(--pri)}
.tb-notif{position:relative;background:none;border:none;color:var(--text2);font-size:1.2rem;cursor:pointer;padding:.3rem}.tb-notif:hover{color:var(--text)}
.tb-notif .dot{position:absolute;top:2px;right:2px;width:7px;height:7px;background:var(--fire);border-radius:50%;border:1.5px solid var(--bg)}
.body{padding:1.5rem;max-width:1400px}
/* Cards & Stats */
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.5rem}
.stat{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r);padding:1.1rem 1rem;position:relative;overflow:hidden;transition:.3s}
.stat:hover{border-color:var(--pri);transform:translateY(-2px)}
.stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat.s1::before{background:linear-gradient(90deg,var(--pri),var(--acc))}.stat.s2::before{background:linear-gradient(90deg,var(--green),var(--cyan))}.stat.s3::before{background:linear-gradient(90deg,var(--amber),var(--gold))}.stat.s4::before{background:linear-gradient(90deg,var(--fire),var(--amber))}
.stat-label{font-size:.65rem;text-transform:uppercase;letter-spacing:2px;color:var(--dim);font-weight:600}
.stat-val{font-family:'JetBrains Mono';font-weight:700;font-size:1.6rem;margin:.2rem 0 .1rem}
.stat-chg{font-size:.7rem;font-family:'JetBrains Mono'}
.stat-chg.up{color:var(--green)}.stat-chg.dn{color:var(--fire)}
.stat-ico{position:absolute;top:.8rem;right:.8rem;font-size:1.3rem;opacity:.4}
/* Panel */
.pnl{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--r);margin-bottom:1.2rem;overflow:hidden}
.pnl-hd{display:flex;justify-content:space-between;align-items:center;padding:.8rem 1rem;border-bottom:1px solid var(--border)}
.pnl-tt{font-family:'Exo 2';font-weight:700;font-size:.95rem;display:flex;align-items:center;gap:.5rem}
.pnl-acts{display:flex;gap:.3rem}
.btn{background:var(--bg-s);border:1px solid var(--border);color:var(--text);font-family:'Chakra Petch';font-weight:600;font-size:.78rem;padding:.4rem .8rem;border-radius:7px;cursor:pointer;transition:.2s;display:flex;align-items:center;gap:.35rem}
.btn:hover{border-color:var(--pri);background:var(--bg-h)}
.btn.pri{background:linear-gradient(135deg,var(--pri),var(--sec));border:none;color:#fff}.btn.pri:hover{box-shadow:0 4px 15px rgba(99,102,241,.3)}
.btn.grn{background:rgba(52,211,153,.1);border-color:rgba(52,211,153,.3);color:var(--green)}.btn.grn:hover{background:rgba(52,211,153,.2)}
.btn.red{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--fire)}.btn.red:hover{background:rgba(239,68,68,.2)}
.btn.amb{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.3);color:var(--amber)}.btn.amb:hover{background:rgba(245,158,11,.2)}
/* Table */
.tbl{width:100%;border-collapse:collapse}
.tbl th{text-align:left;font-size:.65rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--dim);font-weight:600;padding:.6rem 1rem;border-bottom:1px solid var(--border)}
.tbl td{padding:.65rem 1rem;border-bottom:1px solid rgba(30,30,58,.5);font-size:.82rem;vertical-align:middle}
.tbl tr:hover td{background:rgba(99,102,241,.03)}
.tbl .mono{font-family:'JetBrains Mono';font-size:.78rem}
.chip{display:inline-block;font-size:.6rem;font-weight:700;padding:.15rem .5rem;border-radius:50px;text-transform:uppercase;letter-spacing:1px}
.chip-ok{background:rgba(52,211,153,.12);color:var(--green)}.chip-warn{background:rgba(245,158,11,.12);color:var(--amber)}.chip-err{background:rgba(239,68,68,.12);color:var(--fire)}.chip-info{background:rgba(99,102,241,.12);color:var(--pri-l)}
.chip-sec{background:rgba(167,139,250,.12);color:var(--acc)}
.avatar-sm{width:28px;height:28px;border-radius:50%;background:var(--bg-e);display:inline-flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;margin-right:.4rem;vertical-align:middle}
/* Tabs */
.tabs{display:flex;gap:.2rem;padding:.6rem 1rem;border-bottom:1px solid var(--border);background:var(--bg-s)}
.tab{background:none;border:none;color:var(--text2);font-family:'Chakra Petch';font-weight:600;font-size:.78rem;padding:.35rem .7rem;border-radius:6px;cursor:pointer;transition:.2s}
.tab:hover{color:var(--text);background:var(--bg-h)}.tab.on{color:var(--pri-l);background:rgba(99,102,241,.1)}
/* Forms */
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;padding:.8rem 1rem}
.form-row.full{grid-template-columns:1fr}
.form-grp{display:flex;flex-direction:column;gap:.2rem}
.form-lbl{font-size:.65rem;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:1.5px}
.form-inp{background:var(--bg-s);border:1px solid var(--border);color:var(--text);font-family:'Chakra Petch';font-size:.85rem;padding:.5rem .7rem;border-radius:7px;outline:none;transition:border .2s}
.form-inp:focus{border-color:var(--pri)}
select.form-inp{cursor:pointer}
textarea.form-inp{min-height:80px;resize:vertical}
/* Chart placeholder */
.chart{background:var(--bg-s);border:1px dashed var(--border);border-radius:8px;height:180px;display:flex;align-items:center;justify-content:center;color:var(--dim);font-size:.82rem;margin:.8rem 1rem}
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:120px;padding:0 1rem .8rem}
.chart-bar{flex:1;background:linear-gradient(180deg,var(--pri),var(--sec));border-radius:4px 4px 0 0;min-width:20px;position:relative;transition:.3s}
.chart-bar:hover{opacity:.8}
.chart-bar-lbl{position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);font-size:.5rem;color:var(--dim);white-space:nowrap}
/* Alerts */
.alert{display:flex;align-items:center;gap:.6rem;padding:.7rem 1rem;margin:.6rem 1rem;border-radius:8px;font-size:.82rem}
.alert-info{background:rgba(99,102,241,.06);border:1px solid rgba(99,102,241,.15);color:var(--pri-l)}
.alert-warn{background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.15);color:var(--amber)}
.alert-ok{background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.15);color:var(--green)}
/* Empty */
.empty{text-align:center;padding:2.5rem;color:var(--dim)}
.empty .ei{font-size:2rem;margin-bottom:.5rem}.empty .et{font-size:.9rem;color:var(--text2)}
/* Pages */
.pg{display:none;animation:fi .25s ease}.pg.on{display:block}
@keyframes fi{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
/* Modal */
.modal-bg{position:fixed;inset:0;background:rgba(4,4,8,.85);backdrop-filter:blur(10px);z-index:200;display:none;align-items:center;justify-content:center}.modal-bg.on{display:flex}
.modal{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.5rem;max-width:500px;width:92%;animation:fi .25s ease}
.modal h2{font-family:'Exo 2';font-weight:700;font-size:1rem;margin-bottom:.8rem;display:flex;align-items:center;gap:.5rem}
.modal-close{float:right;background:none;border:none;color:var(--dim);font-size:1.2rem;cursor:pointer}.modal-close:hover{color:var(--text)}
.modal-foot{display:flex;justify-content:flex-end;gap:.4rem;margin-top:1rem}
/* Toast */
.toast{position:fixed;bottom:1.2rem;right:1.2rem;background:var(--bg-e);border:1px solid var(--border);border-radius:var(--r);padding:.7rem 1.1rem;z-index:300;display:flex;align-items:center;gap:.5rem;transform:translateY(100px);transition:.4s cubic-bezier(.23,1,.32,1);font-size:.85rem;box-shadow:0 10px 35px rgba(0,0,0,.5)}
.toast.on{transform:translateY(0)}.toast.ok{border-color:var(--green)}.toast.err{border-color:var(--fire)}
/* Responsive */
@media(max-width:900px){.side{transform:translateX(-100%)}.side.open{transform:translateX(0)}.content{margin-left:0}.body{padding:1rem}.stats{grid-template-columns:1fr 1fr}.form-row{grid-template-columns:1fr}.tb-search{width:160px}}
.hamburger{display:none;background:none;border:none;color:var(--text);font-size:1.3rem;cursor:pointer;padding:.3rem}
@media(max-width:900px){.hamburger{display:block}}
</style>
</head>
<body>
<!-- SIDEBAR -->
<aside class="side" id="sidebar">
  <div class="s-logo"><div class="s-logo-i">V</div><div><div class="s-logo-t">VAULTA</div><div class="s-logo-sub">Admin Panel</div></div></div>
  <nav class="s-nav">
    <div class="s-sec">Principal</div>
    <button class="s-btn on" data-p="dash" onclick="goA('dash')"><span class="ico">📊</span>Dashboard</button>
    <div class="s-sec">Gestion</div>
    <button class="s-btn" data-p="stock" onclick="goA('stock')"><span class="ico">📦</span>Stocks & Produits</button>
    <button class="s-btn" data-p="tcg" onclick="goA('tcg')"><span class="ico">🎴</span>TCG & Séries</button>
    <button class="s-btn" data-p="orders" onclick="goA('orders')"><span class="ico">🚚</span>Commandes<span class="badge">3</span></button>
    <button class="s-btn" data-p="mkt" onclick="goA('mkt')"><span class="ico">💱</span>Marché</button>
    <div class="s-sec">Utilisateurs</div>
    <button class="s-btn" data-p="users" onclick="goA('users')"><span class="ico">👥</span>Utilisateurs</button>
    <button class="s-btn" data-p="support" onclick="goA('support')"><span class="ico">🎧</span>Support<span class="badge">5</span></button>
    <div class="s-sec">Finance</div>
    <button class="s-btn" data-p="finance" onclick="goA('finance')"><span class="ico">💰</span>Finance</button>
    <div class="s-sec">Système</div>
    <button class="s-btn" data-p="settings" onclick="goA('settings')"><span class="ico">⚙️</span>Paramètres</button>
  </nav>
  <div class="s-foot"><div class="s-av">A</div><div><div class="s-uname">Admin</div><div class="s-urole">Super Admin</div></div></div>
</aside>
<!-- MAIN -->
<div class="content">
  <div class="topbar">
    <button class="hamburger" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
    <div class="tb-title" id="tbTitle">Dashboard</div>
    <input class="tb-search" placeholder="Rechercher..." id="globalSearch">
    <button class="tb-notif">🔔<span class="dot"></span></button>
  </div>

  <!-- ===== DASHBOARD ===== -->
  <div class="pg on" id="p-dash"><div class="body">
    <div class="stats">
      <div class="stat s1"><div class="stat-label">Utilisateurs</div><div class="stat-val">1,247</div><div class="stat-chg up">↑ +12% ce mois</div><div class="stat-ico">👥</div></div>
      <div class="stat s2"><div class="stat-label">Boosters ouverts</div><div class="stat-val">8,432</div><div class="stat-chg up">↑ +23% ce mois</div><div class="stat-ico">📦</div></div>
      <div class="stat s3"><div class="stat-label">Chiffre d'affaires</div><div class="stat-val">46,320€</div><div class="stat-chg up">↑ +18%</div><div class="stat-ico">💰</div></div>
      <div class="stat s4"><div class="stat-label">Tickets ouverts</div><div class="stat-val">5</div><div class="stat-chg dn">↑ +2 aujourd'hui</div><div class="stat-ico">🎧</div></div>
    </div>
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:1rem">
      <div class="pnl"><div class="pnl-hd"><div class="pnl-tt">📈 Ventes (7 derniers jours)</div></div>
        <div class="chart-bars" style="padding:1rem">
          <div class="chart-bar" style="height:45%"><div class="chart-bar-lbl">Lun</div></div>
          <div class="chart-bar" style="height:65%"><div class="chart-bar-lbl">Mar</div></div>
          <div class="chart-bar" style="height:50%"><div class="chart-bar-lbl">Mer</div></div>
          <div class="chart-bar" style="height:80%"><div class="chart-bar-lbl">Jeu</div></div>
          <div class="chart-bar" style="height:70%"><div class="chart-bar-lbl">Ven</div></div>
          <div class="chart-bar" style="height:100%"><div class="chart-bar-lbl">Sam</div></div>
          <div class="chart-bar" style="height:90%"><div class="chart-bar-lbl">Dim</div></div>
        </div>
      </div>
      <div class="pnl"><div class="pnl-hd"><div class="pnl-tt">🔥 Alertes</div></div>
        <div class="alert alert-warn">⚠️ Stock bas : Forces Temporelles (6 restants)</div>
        <div class="alert alert-info">ℹ️ 3 commandes en attente d'envoi</div>
        <div class="alert alert-ok">✅ Paiement Stripe opérationnel</div>
      </div>
    </div>
    <div class="pnl"><div class="pnl-hd"><div class="pnl-tt">🕐 Activité récente</div></div>
      <table class="tbl"><thead><tr><th>Heure</th><th>Action</th><th>Utilisateur</th><th>Détail</th></tr></thead><tbody>
        <tr><td class="mono">14:32</td><td>Ouverture booster</td><td><span class="avatar-sm" style="background:var(--pri)">DM</span>DragonMaster</td><td>Flammes Obsidiennes ×2</td></tr>
        <tr><td class="mono">14:28</td><td>Dépôt</td><td><span class="avatar-sm" style="background:var(--green)">PT</span>PsyTrainer</td><td class="mono" style="color:var(--green)">+25.00€</td></tr>
        <tr><td class="mono">14:15</td><td>Vente marché</td><td><span class="avatar-sm" style="background:var(--amber)">IK</span>IceKing</td><td>Chien-Pao ex → 38.00€</td></tr>
        <tr><td class="mono">13:55</td><td>Inscription</td><td><span class="avatar-sm" style="background:var(--sec)">NW</span>NewUser42</td><td>Nouvel utilisateur</td></tr>
        <tr><td class="mono">13:40</td><td>Envoi demandé</td><td><span class="avatar-sm" style="background:var(--fire)">DF</span>DragonFan</td><td>3 cartes → Paris</td></tr>
      </tbody></table>
    </div>
  </div></div>

  <!-- ===== STOCKS ===== -->
  <div class="pg" id="p-stock"><div class="body">
    <div class="stats">
      <div class="stat s1"><div class="stat-label">Boosters en stock</div><div class="stat-val" id="totalStock">107</div><div class="stat-ico">📦</div></div>
      <div class="stat s2"><div class="stat-label">Valeur stock</div><div class="stat-val">588.50€</div><div class="stat-ico">💎</div></div>
      <div class="stat s3"><div class="stat-label">Sets actifs</div><div class="stat-val">6</div><div class="stat-ico">🎴</div></div>
      <div class="stat s4"><div class="stat-label">Alertes stock</div><div class="stat-val">2</div><div class="stat-ico">⚠️</div></div>
    </div>
    <div class="pnl">
      <div class="pnl-hd"><div class="pnl-tt">📦 Gestion des stocks</div><div class="pnl-acts">
        <select class="form-inp" style="padding:.3rem .5rem;font-size:.75rem" id="stockTCGFilter" onchange="renderStock()"><option value="all">Tous les TCG</option><option value="Pokémon">Pokémon</option><option value="One Piece">One Piece</option><option value="Yu-Gi-Oh!">Yu-Gi-Oh!</option><option value="Dragon Ball">Dragon Ball</option><option value="Magic">Magic</option></select>
        <button class="btn pri" onclick="openModal('addProd')">+ Ajouter un produit</button>
      </div></div>
      <table class="tbl" id="stockTable"><thead><tr><th>Produit</th><th>TCG</th><th>Série</th><th>Prix</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody id="stockBody"></tbody>
      </table>
    </div>
  </div></div>

  <!-- ===== TCG & SERIES ===== -->
  <div class="pg" id="p-tcg"><div class="body">
    <div class="pnl">
      <div class="pnl-hd"><div class="pnl-tt">🎴 Franchises TCG</div><div class="pnl-acts"><button class="btn pri" onclick="openModal('addTCG')">+ Ajouter TCG</button></div></div>
      <table class="tbl"><thead><tr><th>TCG</th><th>Séries</th><th>Produits</th><th>Status</th><th>Actions</th></tr></thead><tbody>
        <tr><td><strong>Pokémon</strong></td><td class="mono">1 série</td><td class="mono">6 produits</td><td><span class="chip chip-ok">Actif</span></td><td><button class="btn" onclick="toast('Modifier Pokémon','ok')">✏️</button></td></tr>
        <tr><td style="color:var(--dim)">One Piece</td><td class="mono">0</td><td class="mono">0</td><td><span class="chip chip-warn">Bientôt</span></td><td><button class="btn" onclick="toast('En préparation','ok')">⏳</button></td></tr>
        <tr><td style="color:var(--dim)">Yu-Gi-Oh!</td><td class="mono">0</td><td class="mono">0</td><td><span class="chip chip-warn">Bientôt</span></td><td><button class="btn">⏳</button></td></tr>
        <tr><td style="color:var(--dim)">Dragon Ball</td><td class="mono">0</td><td class="mono">0</td><td><span class="chip chip-warn">Planifié</span></td><td><button class="btn">⏳</button></td></tr>
        <tr><td style="color:var(--dim)">Magic: The Gathering</td><td class="mono">0</td><td class="mono">0</td><td><span class="chip chip-warn">Planifié</span></td><td><button class="btn">⏳</button></td></tr>
      </tbody></table>
    </div>
    <div class="pnl">
      <div class="pnl-hd"><div class="pnl-tt">📚 Séries — Pokémon</div><div class="pnl-acts"><button class="btn pri" onclick="openModal('addSeries')">+ Ajouter Série</button></div></div>
      <table class="tbl"><thead><tr><th>Série</th><th>Sets</th><th>Cartes totales</th><th>Status</th><th>Actions</th></tr></thead><tbody>
        <tr><td><strong>Écarlate & Violet</strong></td><td class="mono">6</td><td class="mono">72 cartes</td><td><span class="chip chip-ok">Active</span></td><td><div class="pnl-acts"><button class="btn" onclick="toast('Modifier la série','ok')">✏️</button><button class="btn red">🗑️</button></div></td></tr>
      </tbody></table>
    </div>
