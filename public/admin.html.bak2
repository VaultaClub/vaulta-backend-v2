    <div class="form-row"><div class="form-grp"><div class="form-lbl">TCG</div><select class="form-inp"><option>Pokémon</option></select></div><div class="form-grp"><div class="form-lbl">Série</div><select class="form-inp"><option>Écarlate & Violet</option></select></div></div>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Nom du set</div><input class="form-inp" placeholder="Ex: Flammes Obsidiennes"></div><div class="form-grp"><div class="form-lbl">Prix booster (€)</div><input class="form-inp" type="number" step="0.01" placeholder="5.50"></div></div>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Cartes par booster</div><input class="form-inp" type="number" value="10"></div><div class="form-grp"><div class="form-lbl">Stock initial</div><input class="form-inp" type="number" placeholder="100"></div></div>
    <div class="form-row full"><div class="form-grp"><div class="form-lbl">Réf vidéo booster IRL</div><input class="form-inp" placeholder="Référence unique du booster physique"></div></div>
    <div class="modal-foot"><button class="btn" onclick="closeModal('addProdModal')">Annuler</button><button class="btn pri" onclick="toast('Produit ajouté !','ok');closeModal('addProdModal')">Ajouter</button></div>
  </div>
</div>
<div class="modal-bg" id="addTCGModal">
  <div class="modal"><button class="modal-close" onclick="closeModal('addTCGModal')">×</button>
    <h2>🎴 Ajouter un TCG</h2>
    <div class="form-row full"><div class="form-grp"><div class="form-lbl">Nom de la franchise</div><input class="form-inp" placeholder="Ex: One Piece Card Game"></div></div>
    <div class="form-row full"><div class="form-grp"><div class="form-lbl">Description</div><textarea class="form-inp" placeholder="Description courte..."></textarea></div></div>
    <div class="modal-foot"><button class="btn" onclick="closeModal('addTCGModal')">Annuler</button><button class="btn pri" onclick="toast('TCG ajouté !','ok');closeModal('addTCGModal')">Ajouter</button></div>
  </div>
</div>
<div class="modal-bg" id="addSeriesModal">
  <div class="modal"><button class="modal-close" onclick="closeModal('addSeriesModal')">×</button>
    <h2>📚 Ajouter une série</h2>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">TCG</div><select class="form-inp"><option>Pokémon</option></select></div><div class="form-grp"><div class="form-lbl">Nom de la série</div><input class="form-inp" placeholder="Ex: Noir & Blanc"></div></div>
    <div class="modal-foot"><button class="btn" onclick="closeModal('addSeriesModal')">Annuler</button><button class="btn pri" onclick="toast('Série ajoutée !','ok');closeModal('addSeriesModal')">Ajouter</button></div>
  </div>
</div>
<div class="modal-bg" id="editUserModal">
  <div class="modal"><button class="modal-close" onclick="closeModal('editUserModal')">×</button>
    <h2>✏️ Modifier l'utilisateur</h2>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Pseudo</div><input class="form-inp" value="DragonMaster"></div><div class="form-grp"><div class="form-lbl">Email</div><input class="form-inp" value="dragon@mail.com"></div></div>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Rôle</div><select class="form-inp"><option>Utilisateur</option><option>Modérateur</option><option>Admin</option></select></div><div class="form-grp"><div class="form-lbl">Solde (€)</div><input class="form-inp" type="number" value="124.50"></div></div>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Status</div><select class="form-inp"><option>Actif</option><option>Suspendu</option><option>Banni</option></select></div><div class="form-grp"><div class="form-lbl">Niveau XP</div><input class="form-inp" type="number" value="8"></div></div>
    <div class="form-row full"><div class="form-grp"><div class="form-lbl">Note admin</div><textarea class="form-inp" placeholder="Note interne..."></textarea></div></div>
    <div class="modal-foot"><button class="btn" onclick="closeModal('editUserModal')">Annuler</button><button class="btn pri" onclick="toast('Utilisateur modifié','ok');closeModal('editUserModal')">Sauvegarder</button></div>
  </div>
</div>
<div class="modal-bg" id="ticketModal">
  <div class="modal"><button class="modal-close" onclick="closeModal('ticketModal')">×</button>
    <h2>📝 Ticket #TK-412</h2>
    <div style="background:var(--bg-s);border-radius:8px;padding:.7rem;margin-bottom:.7rem">
      <div style="display:flex;justify-content:space-between;margin-bottom:.3rem"><strong style="font-size:.85rem">@DragonFan</strong><span class="mono" style="font-size:.7rem;color:var(--dim)">25/02/26 10:15</span></div>
      <p style="font-size:.82rem;color:var(--text2)">Bonjour, j'ai commandé 3 cartes il y a 5 jours (CMD-2841) et je n'ai toujours rien reçu. Pouvez-vous vérifier le suivi ?</p>
    </div>
    <div class="form-row full"><div class="form-grp"><div class="form-lbl">Réponse</div><textarea class="form-inp" placeholder="Tapez votre réponse..."></textarea></div></div>
    <div class="form-row"><div class="form-grp"><div class="form-lbl">Status</div><select class="form-inp"><option>En traitement</option><option>Résolu</option><option>En attente client</option></select></div><div class="form-grp"><div class="form-lbl">Priorité</div><select class="form-inp"><option>Urgent</option><option>Moyen</option><option>Bas</option></select></div></div>
    <div class="modal-foot"><button class="btn" onclick="closeModal('ticketModal')">Annuler</button><button class="btn pri" onclick="toast('Réponse envoyée','ok');closeModal('ticketModal')">📨 Envoyer</button></div>
  </div>
</div>
<!-- TOAST -->
<div class="toast" id="toast"><span id="tI"></span><span id="tT"></span></div>

<script>
const products=[
  {name:'Flammes Obsidiennes',tcg:'Pokémon',series:'Écarlate & Violet',price:5.50,stock:24,cards:12},
  {name:'Évolutions à Paldea',tcg:'Pokémon',series:'Écarlate & Violet',price:5.50,stock:15,cards:9},
  {name:'151',tcg:'Pokémon',series:'Écarlate & Violet',price:6.90,stock:12,cards:10},
  {name:'Faille Paradoxe',tcg:'Pokémon',series:'Écarlate & Violet',price:5.50,stock:20,cards:8},
  {name:'Forces Temporelles',tcg:'Pokémon',series:'Écarlate & Violet',price:5.50,stock:6,cards:7},
  {name:'Masque Crépusculaire',tcg:'Pokémon',series:'Écarlate & Violet',price:5.50,stock:30,cards:7}
];
function goA(pg){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));
  document.getElementById('p-'+pg).classList.add('on');
  document.querySelectorAll('.s-btn').forEach(b=>b.classList.toggle('on',b.dataset.p===pg));
  const titles={dash:'Dashboard',stock:'Stocks & Produits',tcg:'TCG & Séries',orders:'Commandes',mkt:'Marché',users:'Utilisateurs',support:'Support',finance:'Finance',settings:'Paramètres'};
  document.getElementById('tbTitle').textContent=titles[pg]||'Dashboard';
  document.getElementById('sidebar').classList.remove('open');
  if(pg==='stock')renderStock();if(pg==='tcg')renderSets();
}
function renderStock(){
  const filt=document.getElementById('stockTCGFilter').value;
  const filtered=filt==='all'?products:products.filter(p=>p.tcg===filt);
  document.getElementById('stockBody').innerHTML=filtered.map(p=>{
    const ri=products.indexOf(p);
    const sc=p.stock>10?'chip-ok':p.stock>3?'chip-warn':'chip-err';
    const sl=p.stock>10?'En stock':p.stock>3?'Stock bas':'Critique';
    return `<tr><td><strong>${p.name}</strong></td><td>${p.tcg}</td><td>${p.series}</td><td class="mono" style="color:var(--gold)">${p.price.toFixed(2)}€</td><td class="mono">${p.stock}</td><td><span class="chip ${sc}">${sl}</span></td><td><div class="pnl-acts">
      <button class="btn red" onclick="adjStock(${ri},-1)">-1</button>
      <button class="btn" onclick="adjStock(${ri},-5)">-5</button>
      <button class="btn" onclick="adjStock(${ri},+1)">+1</button>
      <button class="btn grn" onclick="adjStock(${ri},+10)">+10</button>
      <button class="btn amb" onclick="editProdPrice(${ri})">✏️</button>
    </div></td></tr>`}).join('');
  document.getElementById('totalStock').textContent=filtered.reduce((s,p)=>s+p.stock,0);
}
function adjStock(i,d){products[i].stock=Math.max(0,products[i].stock+d);renderStock();toast(`Stock ${d>0?'+':'' }${d} pour ${products[i].name}`,'ok')}
function editProdPrice(i){const np=prompt(`Nouveau prix pour ${products[i].name} (actuel: ${products[i].price}€):`,products[i].price);if(np&&!isNaN(np)){products[i].price=parseFloat(np);renderStock();toast(`Prix mis à jour: ${products[i].price.toFixed(2)}€`,'ok')}}
function renderSets(){
  document.getElementById('setsBody').innerHTML=products.map(p=>`<tr><td><strong>${p.name}</strong></td><td class="mono">${p.cards}</td><td class="mono" style="color:var(--gold)">${p.price.toFixed(2)}€</td><td class="mono">${p.stock}</td></tr>`).join('');
}
function openModal(id){document.getElementById(id+'Modal').classList.add('on')}
function closeModal(id){document.getElementById(id).classList.remove('on')}
function toast(msg,type='ok'){const t=document.getElementById('toast');document.getElementById('tI').textContent=type==='ok'?'✅':'❌';document.getElementById('tT').textContent=msg;t.className='toast '+type+' on';setTimeout(()=>t.classList.remove('on'),3500)}
// Init
renderStock();
</script>
</body>
</html>
