# ===========================================
# VAULTA CLUB — Configuration
# Copiez ce fichier en .env et remplissez vos valeurs
# ===========================================

# Serveur
PORT=3000
NODE_ENV=development

# MongoDB — Créez un compte gratuit sur mongodb.com/atlas
MONGO_URI=mongodb+srv://VOTRE_USER:VOTRE_MOT_DE_PASSE@cluster0.xxxxx.mongodb.net/vaultaclub?retryWrites=true&w=majority

# JWT Secret — Générez une chaîne aléatoire longue (ex: openssl rand -hex 64)
JWT_SECRET=CHANGEZ_MOI_une_chaine_secrete_tres_longue_et_aleatoire

# Session Secret
SESSION_SECRET=CHANGEZ_MOI_autre_chaine_secrete

# Stripe — Créez un compte sur stripe.com/fr
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLIQUE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# Email — Pour les notifications (utilisez Gmail, Mailgun, ou SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=votre_mot_de_passe_application
EMAIL_FROM=noreply@vaultaclub.com

# Admin par défaut
ADMIN_EMAIL=admin@vaultaclub.com
ADMIN_PASSWORD=ChangezCeMotDePasse123!

# URL du site
SITE_URL=http://localhost:3000
